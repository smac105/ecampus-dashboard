<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{{ title or site.title }}</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

	<!-- font awesome 6.0 -->
	<script src="https://kit.fontawesome.com/7e5f6c5917.js" crossorigin="anonymous"></script>

	{% include "partials/head-apu.njk" %}

	<!-- Styles -->
	<link rel="stylesheet" href="/css/main.css">
</head>
<body class="overlay-nav-body">
{% from "partials/macros.njk" import button, navIcon, navMenu, banner, productCard, classCard, cardGrid, image %}
{% import "partials/macros.njk" as buttons %}

<div class="dashboard-overlay">
	<!-- Overlay Navigation (Default - for all stages except applicant) -->
	<div id="overlay-nav-default">
		{% include "partials/overlay-nav.njk" %}
	</div>

	<!-- Overlay Navigation (Applicant Stage Only) -->
	<div id="overlay-nav-applicant" style="display: none;">
		{% include "partials/overlay-nav-applicant.njk" %}
	</div>

	<!-- Full Screen Menu Overlay -->
	{% include "partials/overlay-menu.njk" %}

	<div id="main" class="dashboard-app overlay-layout">
		{# <div class="row">
			{% include "partials/top-header.njk" %}
		</div> #}
		<div class="row flex-nowrap">
			<main class="col main-wrap">
			{% include "partials/header.njk" %}

			{% block content %}{% endblock %}
			</main>
		</div>

		{% include "partials/footer.njk" %}
	</div>

	<!-- Registration Cart Modal -->
	{% include "partials/registration/cart-modal.njk" %}

	<!-- Confetti Library -->
	<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>

	<!-- Overlay Navigation JavaScript -->
	<script src="/js/overlay-nav.js"></script>
	<script src="/js/confetti-util.js"></script>
</body>
</html>
