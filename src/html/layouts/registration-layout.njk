<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{{ title or "Course Registration - " + site.title }}</title>
	<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">

	<!-- font awesome 6.0 -->
	<script src="https://kit.fontawesome.com/7e5f6c5917.js" crossorigin="anonymous"></script>

	{% include "partials/branding/head-apu.njk" %}

	<!-- Styles -->
	<link rel="stylesheet" href="/css/main.css">

	<!-- Bootstrap JS (for modals if needed) -->
	<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-MrcW6ZMFYlzcLA8Nl+NtUVF0sA7MsXsP1UyJoMp4YLEuNSfAP+JcXn/tWtIaxVXM" crossorigin="anonymous"></script>

	<!-- Confetti JS -->
	<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js"></script>
</head>
<body class="gray-body-bg">
	<div class="registration-fullscreen">
		<!-- Registration Header -->
		<div class="registration-header-bar">
			<div class="container-fluid">
				<div class="d-flex justify-content-between align-items-center">
					<div>
						{% include "partials/branding/apu-logo.njk" %}
					</div>
					<a href="{{ exitButtonUrl or '/index.html' }}" class="close-btn" id="exitRegistration">
						<i class="fas fa-times"></i> {{ exitButtonText or "Exit Registration" }}
					</a>
				</div>
			</div>
		</div>

		<!-- Registration Content -->
		<div class="registration-content">
			{% block content %}{% endblock %}
		</div>
	</div>

	<!-- Exit Confirmation Modal -->
	{% include "partials/flows/registration/exit-confirmation-modal.njk" %}

	<!-- Confetti Utility -->
	<script src="/js/confetti-util.js"></script>

	{% block scripts %}{% endblock %}
</body>
</html>
