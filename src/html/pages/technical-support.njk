{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/faq.html" class="shortcut-item">
          <span><i class="fa-regular fa-circle-question"></i></span>
          <p>FAQ</p>
        </a>
        <a href="/technical-support.html" class="shortcut-item">
          <span><i class="fa-regular fa-headset"></i></span>
          <p>Technical Support</p>
        </a>
        <a href="/live-chat.html" class="shortcut-item">
          <span><i class="fa-regular fa-messages"></i></span>
          <p>Live Chat</p>
        </a>
        <a href="/contact-us.html" class="shortcut-item">
          <span><i class="fa-regular fa-envelope"></i></span>
          <p>Contact Us</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Technical Support</h1>
        <p class="lead mb-4">Get help with technical issues, login problems, and system access.</p>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Contact IT Help Desk</h3>
              <p><strong>Phone:</strong> 1-800-555-TECH</p>
              <p><strong>Email:</strong> techsupport@apus.edu</p>
              <p><strong>Hours:</strong><br>
              Monday - Friday: 8:00 AM - 8:00 PM EST<br>
              Saturday - Sunday: 10:00 AM - 6:00 PM EST</p>
              <a href="#" class="btn-main btn-sm">Submit Support Ticket</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Common Issues</h3>
              <ul>
                <li><a href="#" class="text-primary">Can't log in to student portal</a></li>
                <li><a href="#" class="text-primary">Password reset instructions</a></li>
                <li><a href="#" class="text-primary">Email not working</a></li>
                <li><a href="#" class="text-primary">Browser compatibility issues</a></li>
                <li><a href="#" class="text-primary">Video not playing in course</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">System Requirements</h3>
              <p><strong>Operating System:</strong> Windows 10+, macOS 10.14+, or Linux</p>
              <p><strong>Browser:</strong> Chrome, Firefox, Safari, or Edge (latest versions)</p>
              <p><strong>Internet:</strong> Broadband connection (5 Mbps minimum)</p>
              <p><strong>Software:</strong> Microsoft Office or equivalent</p>
              <a href="#" class="btn-main btn-sm">View Full Requirements</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Software & Downloads</h3>
              <ul>
                <li><a href="#" class="text-primary">Microsoft Office (free for students)</a></li>
                <li><a href="#" class="text-primary">Adobe Creative Cloud</a></li>
                <li><a href="#" class="text-primary">Antivirus software</a></li>
                <li><a href="#" class="text-primary">Virtual private network (VPN)</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <div class="white-box">
              <h3 class="h3 mb-3">Video Tutorials</h3>
              <p>Watch step-by-step video guides for common technical tasks.</p>
              <ul>
                <li><a href="#" class="text-primary">How to Reset Your Password</a></li>
                <li><a href="#" class="text-primary">Navigating the Student Portal</a></li>
                <li><a href="#" class="text-primary">Accessing Your Email</a></li>
                <li><a href="#" class="text-primary">Troubleshooting Login Issues</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
