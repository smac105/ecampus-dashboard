{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/alumni-network.html" class="shortcut-item">
          <span><i class="fa-regular fa-user-group"></i></span>
          <p>Alumni Network</p>
        </a>
        <a href="/alumni-events.html" class="shortcut-item">
          <span><i class="fa-regular fa-calendar-check"></i></span>
          <p>Alumni Events</p>
        </a>
        <a href="/alumni-benefits.html" class="shortcut-item">
          <span><i class="fa-regular fa-award"></i></span>
          <p>Alumni Benefits</p>
        </a>
        <a href="/get-involved.html" class="shortcut-item">
          <span><i class="fa-regular fa-handshake"></i></span>
          <p>Get Involved</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Alumni</h1>
        <p class="lead mb-4">Stay connected with your alma mater and fellow graduates.</p>

        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3"><i class="fa-regular fa-user-group"></i> Alumni Network</h3>
              <p>Connect with fellow alumni and expand your professional network.</p>
              <a href="#" class="btn-main btn-sm">Join Network</a>
            </div>
          </div>

          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3"><i class="fa-regular fa-calendar-star"></i> Alumni Events</h3>
              <p>Attend reunions, networking events, and professional development workshops.</p>
              <a href="#" class="btn-main btn-sm">View Events</a>
            </div>
          </div>

          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3"><i class="fa-regular fa-award"></i> Alumni Benefits</h3>
              <p>Explore exclusive benefits, discounts, and services for alumni.</p>
              <a href="#" class="btn-main btn-sm">View Benefits</a>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Get Involved</h3>
              <ul>
                <li><a href="#" class="text-primary">Mentorship Program</a></li>
                <li><a href="#" class="text-primary">Guest Speaker Opportunities</a></li>
                <li><a href="#" class="text-primary">Alumni Association Board</a></li>
                <li><a href="#" class="text-primary">Volunteer Opportunities</a></li>
              </ul>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Alumni Resources</h3>
              <ul>
                <li><a href="#" class="text-primary">Career Services for Alumni</a></li>
                <li><a href="#" class="text-primary">Continuing Education</a></li>
                <li><a href="#" class="text-primary">Alumni Directory</a></li>
                <li><a href="#" class="text-primary">Update Contact Information</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
