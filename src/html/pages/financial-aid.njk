{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/tuition-and-fees.html" class="shortcut-item">
          <span><i class="fa-regular fa-money-bill-wave"></i></span>
          <p>Tuition & Fees</p>
        </a>
        <a href="/financial-aid.html" class="shortcut-item">
          <span><i class="fa-regular fa-hand-holding-dollar"></i></span>
          <p>Financial Aid</p>
        </a>
        <a href="/payment-plans.html" class="shortcut-item">
          <span><i class="fa-regular fa-credit-card"></i></span>
          <p>Payment Plans</p>
        </a>
        <a href="/billing-statement.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-invoice-dollar"></i></span>
          <p>Billing Statement</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Financial Aid</h1>
        <p class="lead mb-4">Manage your financial aid applications and awards.</p>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Financial Aid Status</h3>
              <p><strong>FAFSA Status:</strong> Completed</p>
              <p><strong>Award Status:</strong> Awarded</p>
              <p><strong>Total Aid:</strong> $8,500</p>
              <a href="#" class="btn-main btn-sm">View Details</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Apply for Aid</h3>
              <ul>
                <li>Complete FAFSA</li>
                <li>Apply for scholarships</li>
                <li>Student loan applications</li>
                <li>Work-study programs</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Apply Now</a>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Award Letter</h3>
              <p>View and accept your financial aid award letter.</p>
              <a href="#" class="btn-main btn-sm">View Award Letter</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Required Documents</h3>
              <p>Upload required financial aid documentation.</p>
              <a href="#" class="btn-main btn-sm">Upload Documents</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
