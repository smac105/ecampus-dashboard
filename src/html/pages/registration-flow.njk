{% extends "layouts/registration-layout.njk" %}
{% set exitButtonText = "Exit Registration" %}

{% block content %}
<div class="registration-flow">
  <!-- Registration Title -->
  <div class="container">
    <div class="row mb-4">
      <div class="col-12">
        <div class="text-center">
          <h1 class="h1 mb-2">Course Registration</h1>
          <p class="lead mb-0">Spring 2025 Semester</p>
        </div>
      </div>
    </div>
  </div>
  <div class="container mb-5">
  <!-- Progress Tracker -->
  {% include "partials/flows/registration/progress-tracker.njk" %}
  </div>
  <!-- Step Content - All steps pre-rendered, shown/hidden by JavaScript -->
  <div id="step1" class="step-container">
    {% include "partials/flows/registration/step1-courses.njk" %}
  </div>

  <div id="step2" class="step-container" style="display: none;">
    {% include "partials/flows/registration/step2-review-cart.njk" %}
  </div>

  <div id="step3" class="step-container" style="display: none;">
    {% include "partials/flows/registration/step3-payment-disclosures.njk" %}
  </div>

  <div id="step4" class="step-container" style="display: none;">
    {% include "partials/flows/registration/step4-payment-shipping.njk" %}
  </div>

  <div id="step5" class="step-container" style="display: none;">
    {% include "partials/flows/registration/confirmation.njk" %}
  </div>

  <!-- Navigation Buttons -->
  <div class="container">
    <div class="row mt-4 mb-5">
      <div class="col-12">
        <div class="d-flex justify-content-between step-navigation" id="stepNavigation">
          <button id="backBtn" class="btn-secondary back-btn" style="display: none;">
            Back
          </button>
          <button id="nextBtn" class="btn-main ms-auto">
            Next
          </button>
        </div>
      </div>
    </div>
    <!-- Reset Button (Development Only) -->
    <div class="row mb-5">
      <div class="col-12 text-center">
        <button id="resetRegistrationBtn" class="arrow-link reset">
          Reset Registration
        </button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/registration.js"></script>
{% endblock %}