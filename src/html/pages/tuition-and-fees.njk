{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/tuition-and-fees.html" class="shortcut-item">
          <span><i class="fa-regular fa-money-bill-wave"></i></span>
          <p>Tuition & Fees</p>
        </a>
        <a href="/financial-aid.html" class="shortcut-item">
          <span><i class="fa-regular fa-hand-holding-dollar"></i></span>
          <p>Financial Aid</p>
        </a>
        <a href="/payment-plans.html" class="shortcut-item">
          <span><i class="fa-regular fa-credit-card"></i></span>
          <p>Payment Plans</p>
        </a>
        <a href="/billing-statement.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-invoice-dollar"></i></span>
          <p>Billing Statement</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Tuition & Fees</h1>
        <p class="lead mb-4">View tuition rates, fees, and payment information.</p>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Current Balance</h3>
              <p class="h2 mb-3">$4,250.00</p>
              <p><strong>Due Date:</strong> March 15, 2025</p>
              <a href="#" class="btn-main btn-sm">Make Payment</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Tuition Rates</h3>
              <ul>
                <li>Undergraduate: $250/credit hour</li>
                <li>Graduate: $350/credit hour</li>
                <li>Technology Fee: $50/semester</li>
                <li>Student Services Fee: $100/semester</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Payment History</h3>
              <p>View past payments and download receipts.</p>
              <a href="#" class="btn-main btn-sm">View History</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">1098-T Tax Form</h3>
              <p>Download your 1098-T form for tax purposes.</p>
              <a href="#" class="btn-main btn-sm">Download Form</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
