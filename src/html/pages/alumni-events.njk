{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/alumni-network.html" class="shortcut-item">
          <span><i class="fa-regular fa-user-group"></i></span>
          <p>Alumni Network</p>
        </a>
        <a href="/alumni-events.html" class="shortcut-item">
          <span><i class="fa-regular fa-calendar-check"></i></span>
          <p>Alumni Events</p>
        </a>
        <a href="/alumni-benefits.html" class="shortcut-item">
          <span><i class="fa-regular fa-award"></i></span>
          <p>Alumni Benefits</p>
        </a>
        <a href="/get-involved.html" class="shortcut-item">
          <span><i class="fa-regular fa-handshake"></i></span>
          <p>Get Involved</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Alumni Events</h1>
        <p class="lead mb-4">Attend reunions, networking events, and professional development opportunities.</p>

        <div class="row">
          <div class="col-12 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Upcoming Events</h3>

              <div class="mb-4">
                <h4 class="h4">Alumni Homecoming Weekend</h4>
                <p><strong>Date:</strong> April 15-17, 2025</p>
                <p>Join us for our annual homecoming celebration with special events, networking opportunities, and campus tours.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>

              <div class="mb-4">
                <h4 class="h4">Class of 2020 Five-Year Reunion</h4>
                <p><strong>Date:</strong> May 8, 2025 | 6:00 PM - 9:00 PM EST</p>
                <p>Reconnect with your classmates and celebrate five years since graduation.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>

              <div class="mb-4">
                <h4 class="h4">Virtual Alumni Networking Event</h4>
                <p><strong>Date:</strong> March 22, 2025 | 7:00 PM - 8:30 PM EST</p>
                <p>Network with alumni from various industries and career stages.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>

              <div class="mb-4">
                <h4 class="h4">Professional Development Workshop Series</h4>
                <p><strong>Dates:</strong> Monthly, starting April 2025</p>
                <p>Monthly workshops covering leadership, career advancement, and professional skills.</p>
                <a href="#" class="btn-main btn-sm">View Series</a>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <div class="white-box">
              <h3 class="h3 mb-3">Past Event Photos</h3>
              <p>View photos and highlights from recent alumni events.</p>
              <a href="#" class="btn-main btn-sm">View Gallery</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
