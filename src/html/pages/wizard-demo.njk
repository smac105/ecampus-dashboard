{% extends "layouts/base.njk" %}

{% block content %}
<!-- Full-Screen Wizard Overlay -->
<div class="wizard-overlay" id="wizardOverlay">
  <div class="wizard-container">

    <!-- Wizard Header with Progress Bar -->
    <div class="wizard-header">
      <h1 class="wizard-title">Complete Your Profile</h1>
      <p class="wizard-subtitle">Follow these steps to get started</p>

      <!-- Tab-Style Progress Bar -->
      <div class="wizard-progress-tabs">
        <div class="wizard-tab active" data-stage="1">
          <span class="tab-number">1</span>
          <span class="tab-label">Personal Info</span>
        </div>
        <div class="wizard-tab" data-stage="2">
          <span class="tab-number">2</span>
          <span class="tab-label">Preferences</span>
        </div>
        <div class="wizard-tab" data-stage="3">
          <span class="tab-number">3</span>
          <span class="tab-label">Verification</span>
        </div>
        <div class="wizard-tab" data-stage="4">
          <span class="tab-number">4</span>
          <span class="tab-label">Complete</span>
        </div>
      </div>
    </div>

    <!-- Wizard Content Area -->
    <div class="wizard-content">

      <!-- Stage 1: Personal Info -->
      <div class="wizard-stage active" id="wizardStage1">
        <div class="stage-inner">
          <h2 class="stage-title">Personal Information</h2>
          <p class="stage-description">Tell us a bit about yourself</p>

          <form class="wizard-form">
            <div class="form-group">
              <label for="firstName">First Name</label>
              <input type="text" id="firstName" name="firstName" class="form-control" placeholder="Enter your first name" required>
            </div>

            <div class="form-group">
              <label for="lastName">Last Name</label>
              <input type="text" id="lastName" name="lastName" class="form-control" placeholder="Enter your last name" required>
            </div>

            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" class="form-control" placeholder="your.email@example.com" required>
            </div>

            <div class="form-group">
              <label for="phone">Phone Number</label>
              <input type="tel" id="phone" name="phone" class="form-control" placeholder="(555) 123-4567">
            </div>
          </form>
        </div>
      </div>

      <!-- Stage 2: Preferences -->
      <div class="wizard-stage" id="wizardStage2">
        <div class="stage-inner">
          <h2 class="stage-title">Set Your Preferences</h2>
          <p class="stage-description">Customize your experience</p>

          <form class="wizard-form">
            <div class="form-group">
              <label>Notification Preferences</label>
              <div class="form-check">
                <input type="checkbox" id="emailNotif" name="emailNotif" class="form-check-input" checked>
                <label for="emailNotif" class="form-check-label">Email notifications</label>
              </div>
              <div class="form-check">
                <input type="checkbox" id="smsNotif" name="smsNotif" class="form-check-input">
                <label for="smsNotif" class="form-check-label">SMS notifications</label>
              </div>
              <div class="form-check">
                <input type="checkbox" id="pushNotif" name="pushNotif" class="form-check-input" checked>
                <label for="pushNotif" class="form-check-label">Push notifications</label>
              </div>
            </div>

            <div class="form-group">
              <label for="timezone">Time Zone</label>
              <select id="timezone" name="timezone" class="form-control">
                <option value="EST">Eastern Time (EST)</option>
                <option value="CST">Central Time (CST)</option>
                <option value="MST">Mountain Time (MST)</option>
                <option value="PST">Pacific Time (PST)</option>
              </select>
            </div>

            <div class="form-group">
              <label for="language">Preferred Language</label>
              <select id="language" name="language" class="form-control">
                <option value="en">English</option>
                <option value="es">Spanish</option>
                <option value="fr">French</option>
              </select>
            </div>
          </form>
        </div>
      </div>

      <!-- Stage 3: Verification -->
      <div class="wizard-stage" id="wizardStage3">
        <div class="stage-inner">
          <h2 class="stage-title">Verify Your Information</h2>
          <p class="stage-description">Review and confirm your details</p>

          <div class="verification-summary">
            <div class="summary-section">
              <h3>Personal Information</h3>
              <dl class="summary-list">
                <dt>Name:</dt>
                <dd id="summaryName">--</dd>
                <dt>Email:</dt>
                <dd id="summaryEmail">--</dd>
                <dt>Phone:</dt>
                <dd id="summaryPhone">--</dd>
              </dl>
            </div>

            <div class="summary-section">
              <h3>Preferences</h3>
              <dl class="summary-list">
                <dt>Notifications:</dt>
                <dd id="summaryNotifications">--</dd>
                <dt>Time Zone:</dt>
                <dd id="summaryTimezone">--</dd>
                <dt>Language:</dt>
                <dd id="summaryLanguage">--</dd>
              </dl>
            </div>
          </div>

          <div class="form-check mt-4">
            <input type="checkbox" id="confirmAccuracy" name="confirmAccuracy" class="form-check-input" required>
            <label for="confirmAccuracy" class="form-check-label">I confirm that all information provided is accurate</label>
          </div>
        </div>
      </div>

      <!-- Stage 4: Complete -->
      <div class="wizard-stage" id="wizardStage4">
        <div class="stage-inner text-center">
          <div class="success-icon">
            <i class="fas fa-check-circle"></i>
          </div>
          <h2 class="stage-title">All Set!</h2>
          <p class="stage-description">Your profile has been successfully completed</p>

          <div class="completion-message">
            <p>Thank you for completing your profile setup. You're now ready to get started!</p>
            <p>We've sent a confirmation email to <strong id="confirmationEmail">your email address</strong>.</p>
          </div>

          <div class="next-steps">
            <h3>What's Next?</h3>
            <ul>
              <li>Explore your personalized dashboard</li>
              <li>Complete any additional optional settings</li>
              <li>Start using all available features</li>
            </ul>
          </div>
        </div>
      </div>

    </div>

    <!-- Wizard Footer with Navigation -->
    <div class="wizard-footer">
      <button type="button" class="btn-secondary" id="wizardBackBtn" style="display: none;">
        <i class="fas fa-arrow-left"></i> Back
      </button>

      <div class="footer-center">
        <span class="step-indicator">Step <span id="currentStepNum">1</span> of 4</span>
      </div>

      <button type="button" class="btn-main" id="wizardNextBtn">
        Next <i class="fas fa-arrow-right"></i>
      </button>

      <button type="button" class="btn-main" id="wizardCompleteBtn" style="display: none;">
        <i class="fas fa-check"></i> Complete
      </button>
    </div>

    <!-- Close Button -->
    <button type="button" class="wizard-close" id="wizardCloseBtn" aria-label="Close wizard">
      <i class="fas fa-times"></i>
    </button>

  </div>
</div>

<!-- Demo Trigger Button (for testing) -->
<div class="container mt-5 pt-5">
  <div class="row">
    <div class="col-12 text-center">
      <h1>Wizard Demo Page</h1>
      <p class="lead mb-4">Click the button below to launch the wizard</p>
      <button type="button" class="btn-main" id="launchWizardBtn">
        <i class="fas fa-magic"></i> Launch Wizard
      </button>
    </div>
  </div>
</div>

{% endblock %}

{% block scripts %}
<script src="/js/wizard.js"></script>
{% endblock %}
