              </ul>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Loan Forms</h3>
              <ul>
                <li><a href="#" class="text-primary">Student Loan Application</a></li>
                <li><a href="#" class="text-primary">Master Promissory Note</a></li>
                <li><a href="#" class="text-primary">Loan Entrance Counseling</a></li>
                <li><a href="#" class="text-primary">Loan Exit Counseling</a></li>
              </ul>
            </div>
          </div>
        </div>
