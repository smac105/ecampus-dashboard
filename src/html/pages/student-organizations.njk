            <div class="white-box">
              <h3 class="h3 mb-3">Academic Organizations</h3>
              <ul>
                <li>Honor Societies</li>
                <li>Debate Club</li>
                <li>Business Student Association</li>
                <li>Computer Science Club</li>
                <li>Psychology Students Association</li>
              </ul>
              <a href="#" class="btn-main btn-sm">View All</a>
            </div>
          </div>

          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Special Interest Groups</h3>
