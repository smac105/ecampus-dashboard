{% extends "layouts/registration-layout.njk" %}
{# {% set exitButtonText = "Exit Orientation" %} #}

{% block content %}
<div class="registration-flow student-rights-flow">
	{# <div class="container">
		<div class="row mb-4">
			<div class="col-12">
				<div class="text-center">
					<h1 class="h1 mb-2">Student Orientation</h1>
					<p class="lead mb-0">Complete your new student orientation process</p>
				</div>
			</div>
		</div>
	</div> #}

	<!-- Progress Tracker -->
	<div class="container mb-5">
		{% include "partials/stages/progress-tracker.njk" %}
	</div>

	<!-- Step 1: Introduction -->
	<div id="rightsStep1" class="step-container">
		<div class="container">
			<div class="row row-main-layout">
				
				<div class="mb-5">
					<div class="white-box pb-5">
						<h1 class="mb-4">Congratulations on Completing Your Application, Jorge!</h1>
						<h2>Welcome to Student Orientation</h2>

						<div class="info-content">
							<p class="lead">As a member of the American Public University System community, you have certain rights and responsibilities that are essential to maintaining an environment conducive to learning and personal growth.</p>

							<h3>This orientation will cover:</h3>

							<ul>
								<li><strong>Academic Policies</strong> - Understanding academic integrity, grading policies, and student academic rights</li>
								<li><strong>Student Code of Conduct</strong> - Expected behavior and community standards</li>
								<li><strong>Privacy Rights (FERPA)</strong> - How your educational records are protected</li>
								<li><strong>Your Acknowledgment</strong> - Confirming your understanding and agreement</li>
							</ul>
							<div class="alert-alt alert-exclamation alert-blue mt-4">
								<i class="fas fa-info-circle blue me-2"></i>
								<div>
									<p class="mb-0"><em><strong>Note: You must complete all items in the student orientation before proceeding.</em></strong></em></p>
								</div>
							</div>
							<p class="lead"><strong>Estimated time to complete orientation: 15-30 minutes</strong></p>
							{# <div class="alert alert-info mt-4">
								<i class="fas fa-info-circle me-2"></i>
								<strong>Estimated time:</strong> 10-15 minutes
							</div> #}
							<button id="beginOrientationBtn" class="btn-main">Begin Orientation</button>
						</div>
					</div>
				</div>

				<div class="mb-5">
					<div class="actions white-box">
						<h3>Contact Your Enrollment Advisor</h3>
						<p class="mb-sm">Contact your dedicated enrollment advisor today if you get stuck. They are here to support you every step of the way.</p>
						<div class="advisor-wrap">
							<div class="advisor-initial">
								<span class="big-initial"><strong>S</strong></span>
							</div>
							<div>
								<p class="text-advisor mb-2"><span>Stephanie Lastname</span><br>
								<em>Admissions Officer</em></p>
							</div>
						</div>
						<div>
							<p class="mb-0"><i class="fa-solid fa-phone apu-blue-active"></i> <a href="tel:1-877-468-6268">1-877-468-6268</a><br>
							<i class="fa-solid fa-envelope apu-blue-active"></i> <a href="mailto:Stephanie.Lastname@apus.edu">Stephanie.Lastname@apus.edu</a><br>
							<i class="fa-solid fa-clock apu-blue-active"></i> Mon-Fri 8am-8pm EST</p>
						</div>
					</div>
					
				</div>
			</div>
		</div>
	</div>

	<!-- Step 2: Academic Policies -->
	<div id="rightsStep2" class="step-container" style="display: none;">
		<div class="container">
			<div class="row row-main-layout">
				<div>
					<div class="white-box">
						<h2 class="h2 mb-4">Academic Policies</h2>

						<div class="policy-section mb-5">
							<h3 class="mb-3">Academic Integrity</h3>
							<p class="lead">APUS is committed to maintaining the highest standards of academic integrity. All students are expected to:</p>
							<ul class="info-list">
								<li>Submit original work and properly cite all sources</li>
								<li>Avoid plagiarism, cheating, and unauthorized collaboration</li>
								<li>Uphold honest and ethical academic practices in all coursework</li>
								<li>Report suspected violations of academic integrity</li>
							</ul>

							<div class="alert alert-warning mt-3">
								<i class="fas fa-exclamation-triangle me-2"></i>
								Violations of academic integrity may result in course failure, suspension, or dismissal from the university.
							</div>
						</div>

						<div class="policy-section mb-5">
							<h3 class="h3 mb-3">Grading and Assessment</h3>
							<p>Students have the right to:</p>
							<ul class="info-list">
								<li>Receive clear grading criteria and assignment expectations</li>
								<li>Timely feedback on assignments and assessments</li>
								<li>Appeal grades through the proper academic channels</li>
								<li>Access course materials and resources necessary for success</li>
							</ul>
						</div>

						<div class="policy-section">
							<h3 class="h3 mb-3">Attendance and Participation</h3>
							<p>Regular participation in online coursework is required. Students are expected to:</p>
							<ul class="info-list">
								<li>Log in to their courses regularly (at least 3 times per week recommended)</li>
								<li>Complete assignments by posted deadlines</li>
								<li>Participate in discussion forums and collaborative activities</li>
								<li>Communicate with instructors regarding absences or extensions</li>
							</ul>
						</div>
					</div>
				</div>
				<div class="white-box-border orientation-checklist">
					<h3 class="mb-4">Student Orientation Checklist</h3>
					<p class="text-sm mb-4">Complete all items below to proceed:</p>

					<div class="task-list applicant-sequential-list">
						<div class="task-item" data-task-id="check-responsibilities">
							<input type="checkbox" id="check-responsibilities" class="task-checkbox" disabled>
							<label for="check-responsibilities">Student Responsibilities</label>
						</div>
						<div class="task-item" data-task-id="check-tuition">
							<input type="checkbox" id="check-tuition" class="task-checkbox" disabled>
							<label for="check-tuition">Tuition & Fees</label>
						</div>
						<div class="task-item" data-task-id="check-census">
							<input type="checkbox" id="check-census" class="task-checkbox" disabled>
							<label for="check-census">Census Survey</label>
						</div>
						<div class="task-item" data-task-id="check-profile">
							<input type="checkbox" id="check-profile" class="task-checkbox" disabled>
							<label for="check-profile">Complete Your Profile</label>
						</div>
						<div class="task-item" data-task-id="check-info">
							<input type="checkbox" id="check-info" class="task-checkbox" disabled>
							<label for="check-info">Additional Information For Students</label>
						</div>
						<div class="task-item" data-task-id="check-agreement">
							<input type="checkbox" id="check-agreement" class="task-checkbox" disabled>
							<label for="check-agreement">Student Enrollment Agreement</label>
						</div>
						<div class="task-item" data-task-id="check-ecampus">
							<input type="checkbox" id="check-ecampus" class="task-checkbox" disabled>
							<label for="check-ecampus">eCampus Login</label>
						</div>
					</div>

					<div class="checklist-progress mt-4">
						<div class="progress-text mb-2">
							<span id="checklistProgress">0 of 7</span> completed
						</div>
						<div class="progress" style="height: 8px;">
							<div id="checklistProgressBar" class="progress-bar bg-success" role="progressbar" style="width: 0%"></div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Step 3: Student Code of Conduct -->
	<div id="rightsStep3" class="step-container" style="display: none;">
		<div class="container">
			<div class="row">
				<div class="col-lg-10 offset-lg-1">
					<div class="white-box">
						<h2 class="h2 mb-4">Student Code of Conduct</h2>

						<div class="policy-section mb-5">
							<h3 class="h3 mb-3">Community Standards</h3>
							<p>As a member of the APUS community, you are expected to:</p>
							<ul class="info-list">
								<li>Treat all community members with respect and dignity</li>
								<li>Engage in civil discourse, even when opinions differ</li>
								<li>Refrain from harassment, discrimination, or intimidation</li>
								<li>Use university resources responsibly and ethically</li>
								<li>Comply with all federal, state, and local laws</li>
							</ul>
						</div>

						<div class="policy-section mb-5">
							<h3 class="h3 mb-3">Prohibited Conduct</h3>
							<p>The following behaviors are strictly prohibited:</p>
							<ul class="info-list">
								<li>Academic dishonesty in any form</li>
								<li>Harassment or discrimination based on protected characteristics</li>
								<li>Threats, violence, or intimidation of any kind</li>
								<li>Disruption of university operations or learning environment</li>
								<li>Unauthorized access to university systems or data</li>
								<li>Misuse of university technology or resources</li>
							</ul>
						</div>

						<div class="policy-section">
							<h3 class="h3 mb-3">Disciplinary Procedures</h3>
							<p>Students accused of policy violations have the right to:</p>
							<ul class="info-list">
								<li>Written notice of alleged violations</li>
								<li>A fair and impartial hearing process</li>
								<li>Present evidence and witnesses on their behalf</li>
								<li>Appeal decisions through established procedures</li>
							</ul>

							<p class=" mt-3">Sanctions for violations may include warning, probation, suspension, or dismissal, depending on the severity of the infraction.</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Step 4: Privacy Rights (FERPA) -->
	<div id="rightsStep4" class="step-container" style="display: none;">
		<div class="container">
			<div class="row">
				<div class="col-lg-10 offset-lg-1">
					<div class="white-box">
						<h2 class="h2 mb-4">Privacy Rights - FERPA</h2>

						<div class="policy-section mb-5">
							<h3 class="h3 mb-3">What is FERPA?</h3>
							<p>The Family Educational Rights and Privacy Act (FERPA) is a federal law that protects the privacy of your education records. APUS is committed to protecting your privacy in accordance with FERPA regulations.</p>
						</div>

						<div class="policy-section mb-5">
							<h3 class="h3 mb-3">Your Rights Under FERPA</h3>
							<p>You have the right to:</p>
							<ul class="info-list">
								<li><strong>Inspect and Review:</strong> Access your educational records within 45 days of a request</li>
								<li><strong>Request Amendment:</strong> Request corrections to records you believe are inaccurate or misleading</li>
								<li><strong>Consent to Disclosure:</strong> Control disclosure of personally identifiable information from your records</li>
								<li><strong>File Complaints:</strong> File a complaint with the U.S. Department of Education concerning alleged failures to comply with FERPA</li>
							</ul>
						</div>

						<div class="policy-section mb-5">
							<h3 class="h3 mb-3">Directory Information</h3>
							<p>APUS may disclose "directory information" without your consent unless you request otherwise. Directory information includes:</p>
							<ul class="info-list-sm">
								<li>Name, address, telephone number, email address</li>
								<li>Dates of attendance, enrollment status</li>
								<li>Degrees, honors, and awards received</li>
								<li>Most recent educational institution attended</li>
							</ul>

							<p class=" mt-3">You may request to withhold directory information by contacting the Registrar's Office.</p>
						</div>

						<div class="policy-section">
							<h3 class="h3 mb-3">When Information May Be Disclosed</h3>
							<p>APUS may disclose education records without consent to:</p>
							<ul class="info-list-sm">
								<li>School officials with legitimate educational interest</li>
								<li>Other schools to which you are transferring</li>
								<li>Authorized representatives for audit or evaluation purposes</li>
								<li>Parties in connection with financial aid</li>
								<li>Organizations conducting studies for or on behalf of the school</li>
								<li>Accrediting organizations</li>
								<li>Comply with judicial orders or lawfully issued subpoenas</li>
								<li>Appropriate officials in health or safety emergencies</li>
							</ul>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Step 5: Acknowledgment -->
	<div id="rightsStep5" class="step-container" style="display: none;">
		<div class="container">
			<div class="row">
				<div class="col-lg-8 offset-lg-2">
					<div class="white-box">
						<h2 class="h2 mb-4">Acknowledgment and Agreement</h2>

						<div class="info-content mb-5">
							<p>By checking the boxes below, you acknowledge that you have read, understood, and agree to abide by the policies outlined in this review.</p>
						</div>

						<form id="rightsAcknowledgmentForm">
							<div class="form-check mb-4 p-4" style="background: #f5f5f5; border-left: 4px solid #000;">
								<input class="form-check-input" type="checkbox" id="ackAcademic" required>
								<label class="form-check-label ms-3" for="ackAcademic" style="font-size: 1.5rem;">
									<strong>Academic Policies:</strong> I understand and agree to uphold APUS academic integrity standards, grading policies, and attendance expectations.
								</label>
							</div>

							<div class="form-check mb-4 p-4" style="background: #f5f5f5; border-left: 4px solid #000;">
								<input class="form-check-input" type="checkbox" id="ackConduct" required>
								<label class="form-check-label ms-3" for="ackConduct" style="font-size: 1.5rem;">
									<strong>Student Code of Conduct:</strong> I agree to abide by the APUS Student Code of Conduct and understand the consequences of policy violations.
								</label>
							</div>

							<div class="form-check mb-4 p-4" style="background: #f5f5f5; border-left: 4px solid #000;">
								<input class="form-check-input" type="checkbox" id="ackFERPA" required>
								<label class="form-check-label ms-3" for="ackFERPA" style="font-size: 1.5rem;">
									<strong>Privacy Rights (FERPA):</strong> I understand my rights under FERPA and how APUS protects and may disclose my educational records.
								</label>
							</div>

							<div class="form-check mb-5 p-4" style="background: #f5f5f5; border-left: 4px solid #000;">
								<input class="form-check-input" type="checkbox" id="ackResponsibility" required>
								<label class="form-check-label ms-3" for="ackResponsibility" style="font-size: 1.5rem;">
									<strong>Personal Responsibility:</strong> I take full responsibility for understanding and complying with all university policies, and I will seek clarification when needed.
								</label>
							</div>

							<div class="alert alert-info">
								<i class="fas fa-info-circle me-2"></i>
								Your acknowledgment will be recorded with a timestamp and associated with your student record.
							</div>
						</form>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Confirmation Page -->
	<div id="rightsConfirmation" class="step-container" style="display: none;">
		<div class="container">
			<div class="row">
				<div class="col-lg-8 offset-lg-2">
					<div class="white-box text-center">
						<div class="confirmation-icon mb-4">
							<i class="fas fa-check-circle" style="font-size: 8rem; color: #00ffff;"></i>
						</div>

						<h2 class="h2 mb-4">Acknowledgment Complete!</h2>

						<p class=" mb-4">Thank you for reviewing and acknowledging the APUS Student Rights and Responsibilities. Your acknowledgment has been recorded.</p>

						<div class="confirmation-details p-4 mb-5" style="background: #f5f5f5; text-align: left;">
							<p class="mb-2"><strong>Date Completed:</strong> <span id="completionDate"></span></p>
							<p class="mb-2"><strong>Time:</strong> <span id="completionTime"></span></p>
							<p class="mb-0"><strong>Status:</strong> <span class="text-success fw-bold">Acknowledged</span></p>
						</div>

						<div class="btn-wrap">
							<a href="/index.html" class="btn-main">Return to Dashboard</a>
							<a href="#" id="downloadReceipt" class="btn-secondary ms-3">Download Receipt</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Navigation Buttons -->
	<div class="container">
		<div class="row mt-4 mb-5">
			<div class="col-12">
				<div class="d-flex justify-content-between step-navigation">
					<button id="rightsBackBtn" class="btn-secondary back-btn" style="visibility: hidden;">Back</button>
					<button id="rightsNextBtn" class="btn-main ms-auto">Next</button>
				</div>
			</div>
		</div>
		<div class="row mb-5">
			<div class="col-12 text-center">
				<button id="resetOrientationBtn" class="arrow-link reset">Reset Orientation</button>
			</div>
		</div>
	</div>
</div>
{% endblock %}

{% block scripts %}
<script src="/js/student-rights.js"></script>
{% endblock %}
