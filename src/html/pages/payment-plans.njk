{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/tuition-and-fees.html" class="shortcut-item">
          <span><i class="fa-regular fa-money-bill-wave"></i></span>
          <p>Tuition & Fees</p>
        </a>
        <a href="/financial-aid.html" class="shortcut-item">
          <span><i class="fa-regular fa-hand-holding-dollar"></i></span>
          <p>Financial Aid</p>
        </a>
        <a href="/payment-plans.html" class="shortcut-item">
          <span><i class="fa-regular fa-credit-card"></i></span>
          <p>Payment Plans</p>
        </a>
        <a href="/billing-statement.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-invoice-dollar"></i></span>
          <p>Billing Statement</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Payment Plans</h1>
        <p class="lead mb-4">Set up flexible payment plans to manage your tuition costs.</p>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Current Payment Plan</h3>
              <p><strong>Plan Type:</strong> 4-Month Plan</p>
              <p><strong>Monthly Payment:</strong> $1,062.50</p>
              <p><strong>Next Due Date:</strong> March 15, 2025</p>
              <p><strong>Payments Remaining:</strong> 2</p>
              <a href="#" class="btn-main btn-sm">Manage Plan</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Available Payment Plans</h3>
              <ul>
                <li>2-Month Payment Plan</li>
                <li>4-Month Payment Plan</li>
                <li>6-Month Payment Plan</li>
                <li>Custom Payment Arrangements</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Enroll in Plan</a>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <div class="white-box">
              <h3 class="h3 mb-3">Payment Plan Benefits</h3>
              <ul>
                <li>Spread tuition costs over multiple months</li>
                <li>No interest charges</li>
                <li>Low enrollment fee</li>
                <li>Automatic monthly payments available</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
