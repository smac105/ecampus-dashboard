              <div class="document-tabs mb-4">
                <a href="#inbox" class="inbox-tab-link active" data-inbox-tab="inbox">
                  <i class="fa-solid fa-inbox"></i> Inbox
                </a>
                <a href="#starred" class="inbox-tab-link" data-inbox-tab="starred">
                  <i class="fa-solid fa-star"></i> Starred
                </a>
                <a href="#trash" class="inbox-tab-link" data-inbox-tab="trash">
                  <i class="fa-solid fa-trash"></i> Trash
                </a>
              </div>

