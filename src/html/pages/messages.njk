{% extends "layouts/registration-layout.njk" %}
{% import "partials/macros.njk" as buttons %}
{% set exitButtonText = "Exit Message Center" %}
{% set exitButtonUrl = "/index.html" %}

{% block content %}
  <div class="container">
    <div class="row row-message-center-layout">
      <!-- Main Content -->
      <div class="mb-5">
        <h1 class="mb-2">Message Center</h1>
        <p class="lead mb-4">View important communications, alerts, and notifications.</p>
        <hr>

        <!-- Tabs -->
        <div class="document-tabs mb-4">
          <a href="#messages" class="tab-link active" data-tab="messages">
            <i class="fa-solid fa-envelope"></i> Messages <span class="badge bg-blue ms-2">4</span>
          </a>
          <a href="#alerts" class="tab-link" data-tab="alerts">
            <i class="fa-solid fa-bell"></i> Alerts <span class="badge bg-red ms-2">2</span>
          </a>
        </div>

        <!-- Tab Content -->
        <div id="messageCenterTabContent">
