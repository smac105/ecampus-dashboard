                </div>

                <!-- Unread Message 4 -->
                <div class="message-item message-unread" data-message-id="message4" data-starred="false" data-trashed="false">
                  <div class="message-checkbox">
                    <input type="checkbox" class="message-select-checkbox" data-message-id="message4" onclick="event.stopPropagation();">
