                    <button class="btn-secondary btn-one-icon btn-sm" id="deleteSelected" style="display: none;">
                      <i class="fa-solid fa-trash"></i> Delete Selected
                    </button>
                    <button class="btn-secondary btn-one-icon btn-sm" id="markAllRead">
                      <i class="fa-solid fa-check"></i> Mark All Read
                    </button>
                  </div>
                </div>

                <!-- Message Items -->
              <div class="message-list" id="inboxMessagesList">
                <!-- Unread Message 1 -->
                <div class="message-item message-unread" data-message-id="message1" data-starred="false" data-trashed="false">
                  <div class="message-checkbox">
                    <input type="checkbox" class="message-select-checkbox" data-message-id="message1" onclick="event.stopPropagation();">
                  </div>
                  <div class="message-content">
                    <div class="message-header">
                      <h4 class="message-sender">Stephanie Lastname</h4>
                      <div class="message-meta">
                        <span class="message-date">10:30 AM</span>
                        <button class="message-star" aria-label="Star message" onclick="event.stopPropagation(); toggleStarMessage(this, 'message1');">
                          <i class="fa-regular fa-star"></i>
                        </button>
                      </div>
                    </div>
                    <p class="message-subject">Welcome to APUS - Next Steps for Your Application</p>
                    <p class="message-preview">Hi Jorge, Welcome to American Public University System! I'm excited to work with you as you complete your application...</p>
                  </div>
                </div>

                <!-- Unread Message 2 -->
                <div class="message-item message-unread" data-message-id="message2" data-starred="false" data-trashed="false">
                  <div class="message-checkbox">
                    <input type="checkbox" class="message-select-checkbox" data-message-id="message2" onclick="event.stopPropagation();">
                  </div>
                  <div class="message-content">
                    <div class="message-header">
                      <h4 class="message-sender">Admissions Office</h4>
                      <div class="message-meta">
                        <span class="message-date">Mar 31</span>
                        <button class="message-star" aria-label="Star message" onclick="event.stopPropagation(); toggleStarMessage(this, 'message2');">
                          <i class="fa-regular fa-star"></i>
                        </button>
                      </div>
                    </div>
                    <p class="message-subject">Action Required: Official Transcripts</p>
                    <p class="message-preview">Your application is currently under review. To complete the process, we need you to submit official transcripts from all previously attended institutions...</p>
