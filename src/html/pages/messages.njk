    // Main tab switching (Messages vs Alerts)
    document.addEventListener('DOMContentLoaded', function() {
      const mainTabLinks = document.querySelectorAll('.document-tabs:not(.document-tabs-horizontal) .tab-link');
      const tabContents = document.querySelectorAll('.tab-content');
      const alertCategoryTabs = document.getElementById('alertCategoryTabs');
      const emptyStatePanel = document.getElementById('emptyStatePanel');
      const alertDetailsPanel = document.getElementById('alertDetailsPanel');
      const messageStats = document.getElementById('messageStats');
      const messageDetailsPanel = document.getElementById('messageDetailsPanel');
      const messageEmptyState = document.getElementById('messageEmptyState');

      // Function to switch main tabs
      function switchMainTab(tabId) {
        // Remove active class from all tabs and contents
        mainTabLinks.forEach(link => link.classList.remove('active'));
        tabContents.forEach(content => content.classList.remove('active'));

        // Add active class to selected tab and content
        const selectedLink = document.querySelector(`.document-tabs:not(.document-tabs-horizontal) .tab-link[data-tab="${tabId}"]`);
        const selectedContent = document.getElementById(tabId);

        if (selectedLink) selectedLink.classList.add('active');
        if (selectedContent) selectedContent.classList.add('active');

        // Show/hide sidebar elements based on tab
        if (tabId === 'alerts') {
          alertCategoryTabs.style.display = 'block';
          emptyStatePanel.style.display = 'block';
          alertDetailsPanel.style.display = 'none';
          messageStats.style.display = 'none';
          messageDetailsPanel.style.display = 'none';
          messageEmptyState.style.display = 'none';
        } else {
          alertCategoryTabs.style.display = 'none';
          emptyStatePanel.style.display = 'none';
          alertDetailsPanel.style.display = 'none';
          messageStats.style.display = 'block';
          messageDetailsPanel.style.display = 'none';
          messageEmptyState.style.display = 'block';
        }
      }

      // Add click handlers to main tab links
      mainTabLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const tabId = this.getAttribute('data-tab');
          switchMainTab(tabId);

          // Update URL without page reload
          const url = new URL(window.location);
          url.searchParams.set('view', tabId);
          window.history.pushState({}, '', url);
        });
      });

      // Check for URL parameter on page load
      const urlParams = new URLSearchParams(window.location.search);
      const viewParam = urlParams.get('view');

      if (viewParam === 'alerts') {
        switchMainTab('alerts');
      } else {
        switchMainTab('messages');
      }

      // Category tab switching (All / Active / Resolved) within Alerts
      const categoryLinks = document.querySelectorAll('.tab-link[data-category]');
      const allAlertsSection = document.getElementById('allAlertsSection');
      const activeSection = document.getElementById('activeAlertsSection');
      const resolvedSection = document.getElementById('resolvedAlertsSection');

      categoryLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const category = this.getAttribute('data-category');

          // Update active tab
          categoryLinks.forEach(l => l.classList.remove('active'));
          this.classList.add('active');

          // Show/hide sections
          if (category === 'all') {
            allAlertsSection.style.display = 'block';
            activeSection.style.display = 'none';
            resolvedSection.style.display = 'none';
          } else if (category === 'active') {
            allAlertsSection.style.display = 'none';
            activeSection.style.display = 'block';
            resolvedSection.style.display = 'none';
          } else {
            allAlertsSection.style.display = 'none';
            activeSection.style.display = 'none';
            resolvedSection.style.display = 'block';
          }

          // Hide alert details when switching categories
          alertDetailsPanel.style.display = 'none';
          emptyStatePanel.style.display = 'block';
        });
      });

      // View alert details
      const viewDetailButtons = document.querySelectorAll('.view-alert-details');
      const detailsContent = document.getElementById('alertDetailsContent');

      viewDetailButtons.forEach(button => {
        button.addEventListener('click', function() {
          const alertId = this.getAttribute('data-alert-id');
          const alert = alertDetails[alertId];

          if (alert) {
            detailsContent.innerHTML = alert.content;
            alertDetailsPanel.style.display = 'block';
            emptyStatePanel.style.display = 'none';
          }
        });
      });

      // Close alert details
      document.getElementById('closeAlertDetails').addEventListener('click', function() {
        alertDetailsPanel.style.display = 'none';
        emptyStatePanel.style.display = 'block';
      });

      // Mark all messages as read
      document.getElementById('markAllRead')?.addEventListener('click', function() {
        const unreadMessages = document.querySelectorAll('.message-unread');
        unreadMessages.forEach(msg => {
          msg.classList.remove('message-unread');
          const sender = msg.querySelector('.message-sender');
          const subject = msg.querySelector('.message-subject');

          if (sender) sender.classList.add('message-sender-read');
          if (subject) subject.classList.add('message-subject-read');

          const indicator = msg.querySelector('.message-indicator');
          if (indicator) indicator.style.opacity = '0';
        });
      });

      // Message item click handlers
      const messageItems = document.querySelectorAll('.message-item[data-message-id]');
      const messageDetailsContent = document.getElementById('messageDetailsContent');

      messageItems.forEach(item => {
        item.addEventListener('click', function() {
          const messageId = this.getAttribute('data-message-id');
          const message = messageDetails[messageId];

          if (message) {
            const messageItem = document.querySelector(`[data-message-id="${messageId}"]`);
            const isStarred = messageItem.getAttribute('data-starred') === 'true';
            const isTrashed = messageItem.getAttribute('data-trashed') === 'true';

            // Build message details HTML
            const messageHTML = `
              <div class="message-details">
                <div class="message-details-header mb-4">
                  <h4 class="mb-2">${message.subject}</h4>
                  <div class="d-flex justify-content-between align-items-center mb-3">
                    <div>
                      <p class="mb-0"><strong>From:</strong> ${message.sender}</p>
                      <p class="mb-0 text-muted"><strong>Date:</strong> ${message.date}</p>
                    </div>
                    <div class="d-flex gap-2">
                      <button class="message-star ${isStarred ? 'starred' : ''}" aria-label="Star message" onclick="toggleStarMessage(this, '${messageId}');">
                        <i class="fa-${isStarred ? 'solid' : 'regular'} fa-star"></i>
                      </button>
                      ${!isTrashed ? `
                        <button class="btn-secondary btn-one-icon btn-sm" onclick="deleteMessage('${messageId}');">
                          <i class="fa-solid fa-trash"></i> Delete
                        </button>
                      ` : `
                        <button class="btn-secondary btn-one-icon btn-sm" onclick="restoreMessage('${messageId}');">
                          <i class="fa-solid fa-trash-arrow-up"></i> Restore
                        </button>
                        <button class="btn-secondary btn-one-icon btn-sm" onclick="permanentlyDeleteMessage('${messageId}');">
                          <i class="fa-solid fa-trash"></i> Delete Permanently
                        </button>
                      `}
                    </div>
                  </div>
                  <hr>
                </div>
                <div class="message-details-body">
                  ${message.content}
                </div>
              </div>
            `;

            messageDetailsContent.innerHTML = messageHTML;
            messageDetailsPanel.style.display = 'block';
            messageEmptyState.style.display = 'none';

            // Mark message as read
            if (this.classList.contains('message-unread')) {
              this.classList.remove('message-unread');
              const sender = this.querySelector('.message-sender');
              const subject = this.querySelector('.message-subject');

              if (sender) sender.classList.add('message-sender-read');
              if (subject) subject.classList.add('message-subject-read');
            }

            // Remove active class from all messages and add to clicked one
            messageItems.forEach(msg => msg.classList.remove('active'));
            this.classList.add('active');
          }
        });
      });

      // Mark individual message as read when opened (legacy modal support)
      document.querySelectorAll('[data-bs-toggle="modal"]').forEach(trigger => {
        trigger.addEventListener('click', function() {
          if (this.classList.contains('message-unread')) {
            this.classList.remove('message-unread');
            const sender = this.querySelector('.message-sender');
            const subject = this.querySelector('.message-subject');

            if (sender) sender.classList.add('message-sender-read');
            if (subject) subject.classList.add('message-subject-read');

            const indicator = this.querySelector('.message-indicator');
            if (indicator) {
              indicator.style.opacity = '0';
            }
          }
        });
      });

      // Inbox tab switching
      const inboxTabLinks = document.querySelectorAll('.inbox-tab-link');
      const inboxTabContents = document.querySelectorAll('.inbox-tab-content');

      console.log('Found', inboxTabLinks.length, 'inbox tab links');
      console.log('Found', inboxTabContents.length, 'inbox tab contents');

      inboxTabLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const tabId = this.getAttribute('data-inbox-tab');
          console.log('Inbox tab clicked:', tabId);

          // Update active tab
          inboxTabLinks.forEach(l => l.classList.remove('active'));
          this.classList.add('active');

          // Show/hide tab content
          inboxTabContents.forEach(content => content.classList.remove('active'));
          if (tabId === 'inbox') {
            console.log('Showing inbox content');
            document.getElementById('inboxContent').classList.add('active');
          } else if (tabId === 'starred') {
            console.log('Showing starred content');
            document.getElementById('starredContent').classList.add('active');
            refreshStarredMessages();
          } else if (tabId === 'trash') {
            document.getElementById('trashContent').classList.add('active');
            refreshTrashMessages();
          }
        });
      });

      // Empty Trash button
      document.getElementById('emptyTrash')?.addEventListener('click', function() {
        if (confirm('Are you sure you want to permanently delete all messages in trash? This action cannot be undone.')) {
          const trashedMessages = document.querySelectorAll('[data-trashed="true"]');
          trashedMessages.forEach(msg => msg.remove());
          refreshTrashMessages();

          // Hide message details if showing a trashed message
          messageDetailsPanel.style.display = 'none';
          messageEmptyState.style.display = 'block';
        }
      });

      // Checkbox selection handling
      const checkboxes = document.querySelectorAll('.message-select-checkbox');
      const deleteSelectedBtn = document.getElementById('deleteSelected');

      checkboxes.forEach(checkbox => {
        checkbox.addEventListener('change', function() {
          updateDeleteButtonVisibility();
        });
      });

      function updateDeleteButtonVisibility() {
        const checkedBoxes = document.querySelectorAll('.message-select-checkbox:checked');
        if (checkedBoxes.length > 0) {
          deleteSelectedBtn.style.display = 'inline-block';
        } else {
          deleteSelectedBtn.style.display = 'none';
        }
      }

      // Delete selected messages
      deleteSelectedBtn?.addEventListener('click', function() {
        const checkedBoxes = document.querySelectorAll('.message-select-checkbox:checked');
        if (checkedBoxes.length === 0) return;

        if (confirm(`Are you sure you want to delete ${checkedBoxes.length} selected message(s)?`)) {
          checkedBoxes.forEach(checkbox => {
            const messageId = checkbox.getAttribute('data-message-id');
            deleteMessage(messageId);
          });

          // Uncheck all checkboxes and hide button
          checkboxes.forEach(cb => cb.checked = false);
          deleteSelectedBtn.style.display = 'none';
        }
      });
    });

    // Global functions for message management
    function toggleStarMessage(button, messageId) {
      console.log('toggleStarMessage called for:', messageId);
      const messageItem = document.querySelector(`#inboxMessagesList .message-item[data-message-id="${messageId}"]`);
      if (!messageItem) {
        console.error('Message not found:', messageId);
        return;
      }

      const isStarred = messageItem.getAttribute('data-starred') === 'true';
      const newStarredState = !isStarred;
      console.log('Changing starred state from', isStarred, 'to', newStarredState);
      messageItem.setAttribute('data-starred', newStarredState);

      // Update button appearance
      button.classList.toggle('starred');
      const icon = button.querySelector('i');
      if (icon) {
        icon.classList.toggle('fa-regular');
        icon.classList.toggle('fa-solid');
      }

      // Always refresh starred messages list (even if not currently viewing it)
      // This ensures the starred tab is up to date when the user switches to it
      console.log('Calling refreshStarredMessages');
      refreshStarredMessages();
    }

    function deleteMessage(messageId) {
      console.log('deleteMessage called for:', messageId);
      const messageItem = document.querySelector(`#inboxMessagesList .message-item[data-message-id="${messageId}"]`);
      if (!messageItem) {
        console.error('Message not found for deletion:', messageId);
        return;
      }

      console.log('Setting data-trashed=true for message:', messageId);
      // Mark as trashed
      messageItem.setAttribute('data-trashed', 'true');
      console.log('After setting, data-trashed is:', messageItem.getAttribute('data-trashed'));

      // Hide message details
      const messageDetailsPanel = document.getElementById('messageDetailsPanel');
      const messageEmptyState = document.getElementById('messageEmptyState');
      messageDetailsPanel.style.display = 'none';
      messageEmptyState.style.display = 'block';

      // Always refresh trash messages
      console.log('Calling refreshTrashMessages');
      refreshTrashMessages();

      // Refresh starred if the deleted message was starred
      const isStarred = messageItem.getAttribute('data-starred') === 'true';
      if (isStarred) {
        refreshStarredMessages();
      }
    }

    function restoreMessage(messageId) {
      const messageItem = document.querySelector(`#inboxMessagesList .message-item[data-message-id="${messageId}"]`);
      if (!messageItem) return;

      messageItem.setAttribute('data-trashed', 'false');

      // Hide message details
      const messageDetailsPanel = document.getElementById('messageDetailsPanel');
      const messageEmptyState = document.getElementById('messageEmptyState');
      messageDetailsPanel.style.display = 'none';
      messageEmptyState.style.display = 'block';

      // Refresh trash view
      refreshTrashMessages();

      // Refresh starred if the restored message is starred
      const isStarred = messageItem.getAttribute('data-starred') === 'true';
      if (isStarred) {
        refreshStarredMessages();
      }
    }

    function permanentlyDeleteMessage(messageId) {
      if (confirm('Are you sure you want to permanently delete this message? This action cannot be undone.')) {
        const messageItem = document.querySelector(`#inboxMessagesList .message-item[data-message-id="${messageId}"]`);
        if (messageItem) {
          // Check if starred before removing
          const isStarred = messageItem.getAttribute('data-starred') === 'true';

          messageItem.remove();

          // Hide message details
          const messageDetailsPanel = document.getElementById('messageDetailsPanel');
          const messageEmptyState = document.getElementById('messageEmptyState');
          messageDetailsPanel.style.display = 'none';
          messageEmptyState.style.display = 'block';

          // Refresh trash view
          refreshTrashMessages();

          // Refresh starred if the deleted message was starred
          if (isStarred) {
            refreshStarredMessages();
          }
        }
      }
    }

    function refreshStarredMessages() {
      const starredList = document.getElementById('starredMessagesList');
      // Only get MESSAGE ITEMS from the inbox list, not checkboxes
      const allMessages = document.querySelectorAll('#inboxMessagesList .message-item[data-message-id]');
      console.log('Total messages in inbox:', allMessages.length);

      const starredMessages = Array.from(allMessages).filter(msg => {
        const isStarred = msg.getAttribute('data-starred') === 'true';
        const isTrashed = msg.getAttribute('data-trashed') === 'false';
        console.log('Message', msg.getAttribute('data-message-id'), '- starred:', isStarred, 'trashed:', msg.getAttribute('data-trashed'));
        return isStarred && isTrashed;
      });

      console.log('Starred messages found:', starredMessages.length);

      if (starredMessages.length === 0) {
        console.log('No starred messages, showing empty state');
        starredList.innerHTML = `
          <div class="text-center py-5">
            <i class="fa-regular fa-star" style="font-size: 4rem; color: #ccc; margin-bottom: 1rem;"></i>
            <p class="text-muted mb-0">No starred messages yet</p>
            <p class="text-muted small">Star important messages to find them easily</p>
          </div>
        `;
      } else {
        console.log('Populating starred tab with', starredMessages.length, 'messages');
        starredList.innerHTML = '';
        starredMessages.forEach(msg => {
          const clone = msg.cloneNode(true);
          console.log('Cloning message:', msg.getAttribute('data-message-id'));
          starredList.appendChild(clone);
        });
        console.log('Starred list now has', starredList.children.length, 'children');

        // Reattach click handlers to cloned messages
        starredList.querySelectorAll('.message-item').forEach(item => {
          item.addEventListener('click', function() {
            const messageId = this.getAttribute('data-message-id');
            // Trigger click on original message to show details
            document.querySelector(`#inboxMessagesList .message-item[data-message-id="${messageId}"]`)?.click();
          });
        });
      }
    }

    function refreshTrashMessages() {
      console.log('refreshTrashMessages called');
      const trashList = document.getElementById('trashMessagesList');
      const emptyTrashBtn = document.getElementById('emptyTrash');
      // Only get MESSAGE ITEMS from the inbox list, not checkboxes
      const allMessages = document.querySelectorAll('#inboxMessagesList .message-item[data-message-id]');
      console.log('Total messages in inbox for trash check:', allMessages.length);

      const trashedMessages = Array.from(allMessages).filter(msg => {
        const isTrashed = msg.getAttribute('data-trashed') === 'true';
        console.log('Message', msg.getAttribute('data-message-id'), '- trashed:', isTrashed);
        return isTrashed;
      });

      console.log('Trashed messages found:', trashedMessages.length);

      if (trashedMessages.length === 0) {
        console.log('No trashed messages, showing empty state');
        trashList.innerHTML = `
          <div class="text-center py-5">
            <i class="fa-regular fa-trash-can" style="font-size: 4rem; color: #ccc; margin-bottom: 1rem;"></i>
            <p class="text-muted mb-0">No messages in trash</p>
          </div>
        `;
        if (emptyTrashBtn) emptyTrashBtn.style.display = 'none';
      } else {
        console.log('Populating trash tab with', trashedMessages.length, 'messages');
        trashList.innerHTML = '';
        trashedMessages.forEach(msg => {
          const clone = msg.cloneNode(true);
          console.log('Cloning trashed message:', msg.getAttribute('data-message-id'));
          trashList.appendChild(clone);
        });
        console.log('Trash list now has', trashList.children.length, 'children');
        if (emptyTrashBtn) emptyTrashBtn.style.display = 'inline-block';

        // Reattach click handlers to cloned messages
        trashList.querySelectorAll('.message-item').forEach(item => {
          item.addEventListener('click', function() {
            const messageId = this.getAttribute('data-message-id');
            // Trigger click on original message to show details
            document.querySelector(`#inboxMessagesList .message-item[data-message-id="${messageId}"]`)?.click();
          });
        });
      }
    }
  </script>
{% endblock %}
