                </div>

                <!-- Unread Message 3 -->
                <div class="message-item message-unread" data-message-id="message3" data-starred="false" data-trashed="false">
                  <div class="message-checkbox">
                    <input type="checkbox" class="message-select-checkbox" data-message-id="message3" onclick="event.stopPropagation();">
                  </div>
                  <div class="message-content">
                    <div class="message-header">
                      <h4 class="message-sender">Financial Aid Office</h4>
