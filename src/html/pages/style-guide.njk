        </div>
        <div class="color-swatch" style="background: #ffffff; border: 2px solid #333;">
          <span class="color-swatch-label">White<br>#ffffff</span>
        </div>
      </div>

      <h3>Utility Classes</h3>
      <div class="component-example">
        <p class="red">Red text (.red)</p>
        <p class="green">Green text (.green)</p>
        <p class="orange">Orange text (.orange)</p>
        <p class="blue">Blue text (.blue)</p>
        <p class="gray-dk">Gray dark text (.gray-dk)</p>
      </div>
      <div class="code-example">&lt;p class="red"&gt;Red text&lt;/p&gt;
&lt;p class="apu-blue"&gt;APU Blue text&lt;/p&gt;</div>
    </section>

    <!-- ============================================ -->
    <!-- TYPOGRAPHY SECTION -->
    <!-- ============================================ -->
    <section id="typography" class="section">
      <h2>Typography</h2>
      <p>Heading styles defined in <code>scss/components/_headings-apu.scss</code></p>

      <h3>Headings</h3>
      <div class="component-example">
        <h1>Heading 1 - Main Page Title</h1>
        <h2>Heading 2 - Section Title</h2>
        <h3>Heading 3 - Subsection Title</h3>
        <h4>Heading 4 - Component Title</h4>
      </div>

      <h3>Text Utilities</h3>
      <div class="component-example">
        <p class="small-title">Small Title (.small-title)</p>
        <p class="lead">Lead paragraph with larger text (.lead)</p>
        <p>Base text size (.text-base)</p>
        <p class="text-sm">Small text size (.text-sm)</p>
        <p class="text-lg">Large text size (.text-lg)</p>
      </div>
      <div class="code-example">&lt;h3 class="small-title"&gt;Small Title&lt;/h3&gt;
&lt;p class="lead"&gt;Lead paragraph&lt;/p&gt;
&lt;p class="text-sm"&gt;Small text&lt;/p&gt;</div>
    </section>

    <!-- ============================================ -->
    <!-- BUTTONS SECTION -->
    <!-- ============================================ -->
    <section id="buttons" class="section">
      <h2>Buttons</h2>
      <p>Button styles defined in <code>scss/components/_buttons-apu.scss</code></p>

      <h3>Primary Buttons</h3>
      <div class="component-example">
        <button class="btn btn-main">Primary Button</button>
        {# <button class="btn btn-main" disabled>Disabled Button</button> #}
      </div>
      {# <div class="code-example">&lt;button class="btn btn-main"&gt;Primary Button&lt;/button&gt;
&lt;button class="btn btn-main" disabled&gt;Disabled Button&lt;/button&gt;
&lt;button class="btn btn-main btn-min-width"&gt;Min Width Button&lt;/button&gt;</div>
 #}
      <h3>Secondary Buttons</h3>
      <div class="component-example">
        <button class="btn btn-secondary">Secondary Button</button>
      </div>

      <h3>Disabled Button</h3>
      <div class="component-example">
        <button class="btn btn-secondary" disabled>Disabled Button</button>
      </div>
      <div class="code-example">&lt;button class="btn btn-secondary"&gt;Secondary Button&lt;/button&gt;</div>

      <h3>Link Buttons</h3>
      <div class="component-example">
        <div class="mb-4">
          <a class="arrow-link">Arrow Link</a>
        </div>
        <div class="mb-4">
          <a href="#" class="btn-link-primary">
            <i class="fa-solid fa-eye me-1" aria-hidden="true"></i> View Document
          </a>
        </div>
      </div>
      <div class="code-example">&lt;button class="btn btn-link"&gt;Link Button&lt;/button&gt;</div>

      <h3>Forward and Back Buttons</h3>
      <div class="component-example">
        <div class="d-flex justify-content-between step-navigation mt-0" id="appStepNavigation">
          <button id="appBackBtn" class="btn-main back-btn">
            Back
          </button>
          <button id="appNextBtn" class="btn-main ms-auto">
            Next
          </button>
        </div>
      </div>
      <div class="code-example">&lt;button class="btn btn-link"&gt;Link Button&lt;/button&gt;</div>

      <h3>Button Sizes</h3>
      <div class="component-example">
      <button class="btn btn-main">Default Button</button>
        <button class="btn btn-main btn-sm">Small Button</button>
      </div>
      <div class="code-example">&lt;button class="btn btn-main btn-sm"&gt;Small&lt;/button&gt;
&lt;button class="btn btn-main"&gt;Default&lt;/button&gt;
&lt;button class="btn btn-main btn-lg"&gt;Large&lt;/button&gt;</div>

      <h3>Icon Buttons</h3>
      <div class="component-example">
        <button class="btn btn-main btn-one-icon">
          <i class="fa-solid fa-check"></i> Save
        </button>
        <button class="btn btn-secondary btn-one-icon">
          <i class="fa-solid fa-times"></i> Cancel
        </button>
        <button class="btn btn-main btn-one-icon">
          <i class="fa-solid fa-download"></i> Download
        </button>
      </div>
      <div class="code-example">&lt;button class="btn btn-main"&gt;
  &lt;i class="fa-solid fa-check"&gt;&lt;/i&gt; Save
&lt;/button&gt;</div>
    </section>

    <!-- ============================================ -->
    <!-- FORMS SECTION -->
    <!-- ============================================ -->
    <section id="forms" class="section">
      <h2>Forms</h2>
      <p>Form styles defined in <code>scss/components/_forms.scss</code></p>

      <h3>Text Inputs</h3>
      <div class="component-example">
        <div class="mb-3">
          <label for="input1" class="form-label">Text Input</label>
          <input type="text" class="form-control" id="input1" placeholder="Enter text">
        </div>
        <div class="mb-3">
          <label for="input2" class="form-label">Required Field <span class="red">*</span></label>
          <input type="text" class="form-control" id="input2" required>
        </div>
        <div class="mb-3">
          <label for="input3" class="form-label">Disabled Input</label>
          <input type="text" class="form-control" id="input3" disabled value="Disabled field">
        </div>
      </div>
      <div class="code-example">&lt;div class="mb-3"&gt;
  &lt;label for="input1" class="form-label"&gt;Text Input&lt;/label&gt;
  &lt;input type="text" class="form-control" id="input1"&gt;
&lt;/div&gt;</div>

      <h3>Select Dropdowns</h3>
      <div class="component-example">
        <div class="col-md-6 mb-3">
          <label for="state" class="form-label">State <span class="text-danger">*</span></label>
          <select class="form-control" id="state" name="state" required="">
            <option value="">Select State</option>
            <option value="AL">Alabama</option>
            <option value="AK">Alaska</option>
            <option value="AZ">Arizona</option>
            <option value="CA">California</option>
            <option value="FL">Florida</option>
            <option value="NY">New York</option>
            <option value="TX">Texas</option>
            <!-- Add more states as needed -->
          </select>
        </div>
      </div>
      <div class="code-example">&lt;select class="form-select"&gt;
  &lt;option selected&gt;Choose an option&lt;/option&gt;
  &lt;option value="1"&gt;Option 1&lt;/option&gt;
&lt;/select&gt;</div>

      <h3>Checkboxes & Radios</h3>
      <div class="component-example">
        <div class="form-check mb-2">
          <input class="form-check-input" type="checkbox" id="check1" checked>
          <label class="form-check-label" for="check1">
            Checkbox option 1
          </label>
        </div>
        <div class="form-check mb-3">
          <input class="form-check-input" type="checkbox" id="check2">
          <label class="form-check-label" for="check2">
            Checkbox option 2
          </label>
        </div>
        <div class="form-check mb-2">
          <input class="form-check-input" type="radio" name="radio" id="radio1" checked>
          <label class="form-check-label" for="radio1">
            Radio option 1
          </label>
        </div>
        <div class="form-check">
          <input class="form-check-input" type="radio" name="radio" id="radio2">
          <label class="form-check-label" for="radio2">
            Radio option 2
          </label>
        </div>
      </div>
      <div class="code-example">&lt;div class="form-check"&gt;
  &lt;input class="form-check-input" type="checkbox" id="check1"&gt;
  &lt;label class="form-check-label" for="check1"&gt;
    Checkbox option
  &lt;/label&gt;
&lt;/div&gt;</div>

      <h3>Textarea</h3>
      <div class="component-example">
        <div class="mb-3">
          <label for="textarea1" class="form-label">Textarea</label>
          <textarea class="form-control" id="textarea1" rows="3" placeholder="Enter multiple lines of text"></textarea>
        </div>
      </div>
      <div class="code-example">&lt;textarea class="form-control" rows="3"&gt;&lt;/textarea&gt;</div>
    </section>

    <!-- ============================================ -->
    <!-- ALERTS SECTION -->
    <!-- ============================================ -->
    <section id="alerts" class="section">
      <h2>Alerts</h2>
      <p>Alert styles defined in <code>scss/components/_alerts.scss</code></p>

      <h3>Alert Types</h3>
      <div class="component-example">
        <div class="alert-alt alert-green">
          <i class="fas fa-info-circle mb-3" aria-hidden="true"></i>
          <div>
            <p class="mb-3"><strong>Track Your Status:</strong></p>
            <p class="mb-0">Check your email regularly for updates. You can also contact our admissions office at <strong>1-877-468-6268</strong> or <strong>admissions@apus.edu</strong> for any questions.</p>
          </div>
        </div>

        <div class="alert-alt alert-blue">
          <i class="fas fa-info-circle mb-3" aria-hidden="true"></i>
          <div>
            <p class="mb-3"><strong>Track Your Status:</strong></p>
            <p class="mb-0">Check your email regularly for updates. You can also contact our admissions office at <strong>1-877-468-6268</strong> or <strong>admissions@apus.edu</strong> for any questions.</p>
          </div>
        </div>
        
        <div class="alert-alt alert-exclamation alert-disabled">
          <i class="fa-solid fa-lock" aria-hidden="true"></i>
          <div>
            <p class="mb-0"><strong><em>Financial documents will be available once you have been accepted and complete the pre-enrollment process.</em></strong></p>
          </div>
        </div>
      </div>


      <h3>Dismissible Alerts</h3>
      <div class="component-example">
        <div class="alert-outage" id="outageAlert">
          <button class="alert-close-btn alert-close-btn-outage" id="closeOutageAlert" aria-label="Close alert">
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
          <div class="alert-outage-icon">
            <i class="fa-solid fa-triangle-exclamation" aria-hidden="true"></i>
          </div>
          <div class="alert-outage-content">
            <h4 class="mb-1"><strong>System Maintenance Notice</strong></h4>
            <p class="mb-0">Our systems will be undergoing scheduled maintenance on Sunday, April 6th from 2:00 AM - 6:00 AM EST. Some services may be temporarily unavailable during this time.</p>
          </div>
        </div>
        <div class="alert-alt alert-required" id="transcriptAlert">
          <button class="alert-close-btn" id="closeTranscriptAlert" aria-label="Close alert">
            <i class="fa-solid fa-xmark" aria-hidden="true"></i>
          </button>
          <div>
            <p class="next-step-badge small-title red">ACTION REQUIRED BEFORE ENROLLMENT CAN BEGIN!</p>
            <h3>Request Official Transcripts
              <i class="fa-solid fa-circle-info" data-bs-toggle="popover" data-bs-trigger="focus" data-bs-placement="top" data-bs-content="To complete your application, please submit official transcripts from all previously attended institutions. Transcripts can be sent electronically to transcripts@apus.edu or mailed to our admissions office." tabindex="0" role="button" aria-label="More information about transcript requirements" style="cursor: pointer; font-size: 2rem; margin-left: 0.5rem; color: #0581C0;" aria-hidden="true" data-bs-original-title="" title=""></i>
            </h3>
          </div>
          <div>
            <a href="#" class="btn-main btn-sm">Request Transcripts</a>
          </div>
        </div>
      
      </div>

    </section>

    <!-- ============================================ -->
    <!-- MODALS SECTION -->
    <!-- ============================================ -->
    <section id="modals" class="section">
      <h2>Modals</h2>
      <p>Modal styles defined in <code>scss/components/_modal.scss</code></p>

      <h3>Modal Dialog</h3>
      <div class="component-example">
        <button class="btn btn-main" data-bs-toggle="modal" data-bs-target="#exampleModal">
          Launch Demo Modal
        </button>

        <div class="modal fade" id="exampleModal" tabindex="-1">
          <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
              <div class="modal-header">
                <h3 class="modal-title h3">Modal Title</h3>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <p>This is a modal dialog. It overlays the main content and requires user interaction.</p>
                <p class="mb-0">Modal body content goes here.</p>
              </div>
              <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-min-width" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-main btn-min-width">Save Changes</button>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="code-example">&lt;button data-bs-toggle="modal" data-bs-target="#modal"&gt;Launch Modal&lt;/button&gt;

&lt;div class="modal fade" id="modal"&gt;
  &lt;div class="modal-dialog modal-dialog-centered"&gt;
    &lt;div class="modal-content"&gt;
      &lt;div class="modal-header"&gt;
        &lt;h3 class="modal-title"&gt;Modal Title&lt;/h3&gt;
        &lt;button class="btn-close" data-bs-dismiss="modal"&gt;&lt;/button&gt;
      &lt;/div&gt;
      &lt;div class="modal-body"&gt;Content&lt;/div&gt;
      &lt;div class="modal-footer"&gt;Buttons&lt;/div&gt;
    &lt;/div&gt;
  &lt;/div&gt;
&lt;/div&gt;</div>
    </section>

    <!-- ============================================ -->
    <!-- TABS SECTION -->
    <!-- ============================================ -->
    <section id="tabs" class="section">
      <h2>Tabs</h2>
      <p>Tab styles defined in <code>scss/components/_tabs.scss</code></p>

      <h3>Tab Navigation</h3>
      <!-- Tabbed Navigation -->
  <div class="document-tabs mb-4">
    <a href="#my-todo-list" class="tab-link active" data-tab="my-todo-list">My To-do List</a>
    <a href="#pending-tasks" class="tab-link" data-tab="pending-tasks">Pending</a>
    <a href="#completed-tasks" class="tab-link" data-tab="completed-tasks">Completed</a>
  </div>

  <!-- Tab Content: My To-do List -->
  <div class="tab-content active" id="my-todo-list">
    <!-- Required Items Section -->
    <h4 class="mt-0 mb-3">Required</h4>
    <div class="document-list">
      <div class="document-item mb-2">
        <div class="d-flex align-items-center">
          <i class="fas fa-circle-check apu-blue-active me-3 icon-lg"></i>
          <p class="mb-0"><strong>ID Verification</strong></p>
        </div>
        <a href="#" class="arrow-link arrow-link-sm">
          <i class="fa-solid fa-upload me-1"></i> Upload ID
        </a>
      </div>
      <div class="document-item mb-2">
        <div class="d-flex align-items-center">
          <i class="fas fa-circle-check apu-blue-active me-3 icon-lg"></i>
          <p class="mb-0"><strong>Transfer Credit Evaluation</strong></p>
        </div>
        <a href="/transfer-credits.html" class="arrow-link arrow-link-sm">
          Begin Evaluation
        </a>
      </div>
      <div class="document-item mb-2">
        <div class="d-flex align-items-center">
          <i class="fas fa-circle-check apu-blue-active me-3 icon-lg"></i>
          <p class="mb-0"><strong>Financial Aid Application</strong></p>
        </div>
        <a href="/financial-aid.html" class="arrow-link arrow-link-sm">
          Start Application
        </a>
      </div>
    </div>

    <!-- Additional Items Section -->
    <h4 class="mt-4 mb-2">Not Required - Additional Items</h4>
    <p class="text-muted mb-3">These items are not required for enrollment, but will be required before registering for classes.</p>
    <div class="document-list">
      <div class="document-item mb-2">
