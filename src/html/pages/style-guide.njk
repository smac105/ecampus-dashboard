      <h3>Grayscale</h3>
      <div class="component-example">
        <div class="color-swatch" style="background: #000000;">
          <span class="color-swatch-label">Black<br>#000000</span>
        </div>
        <div class="color-swatch" style="background: #424242;">
          <span class="color-swatch-label">Gray Dark<br>#424242</span>
        </div>
        <div class="color-swatch" style="background: #6b6b6b;">
          <span class="color-swatch-label">Gray 60<br>#6b6b6b</span>
