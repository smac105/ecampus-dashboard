{% extends "layouts/base-styleguide.njk" %}
{% import "partials/macros.njk" as buttons %}

{% block content %}
<style>
.style-guide-nav {
  position: fixed;
  left: 0;
  top: 70px;
  width: 250px;
  height: calc(100vh - 70px);
  background: #f4f4f4;
  border-right: 2px solid #d2d2d2;
  overflow-y: auto;
  padding: 2rem 0;
  z-index: 100;
}

.style-guide-nav ul {
  list-style: none;
  padding: 0;
  margin: 0;
}

.style-guide-nav li {
  margin: 0;
}

.style-guide-nav a {
  display: block;
  padding: 1rem 2rem;
  color: #333;
  text-decoration: none;
  font-size: 1.4rem;
  font-weight: 500;
  transition: all 0.2s ease;
  border-left: 3px solid transparent;
}

.style-guide-nav a:hover,
.style-guide-nav a.active {
  background: #fff;
  border-left-color: #00ffff;
  color: #000;
}

.style-guide-content {
  margin-left: 250px;
  padding: 3rem 4rem;
}

.section {
  margin-bottom: 6rem;
  scroll-margin-top: 90px;
}

.section h2 {
  font-size: 3.2rem;
  margin-bottom: 1rem;
  padding-bottom: 1rem;
  border-bottom: 3px solid #00ffff;
}

.section h3 {
  font-size: 2.4rem;
  margin: 3rem 0 1.5rem;
}

.section h4 {
  font-size: 1.8rem;
  margin: 2rem 0 1rem;
  color: #424242;
}

.component-example {
  background: #fff;
  padding: 3rem;
  border: 1px solid #d2d2d2;
  border-radius: 9px;
  margin-bottom: 2rem;
}
.component-example h4, .component-example .white-box h3 {
  margin: 0rem 0 1.5rem;
}
.color-swatch {
  display: inline-block;
  width: 120px;
  height: 120px;
  border-radius: 9px;
  margin: 1rem 1rem 1rem 0;
  border: 2px solid #d2d2d2;
  position: relative;
}

.color-swatch-label {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 0.5rem;
  font-size: 1.2rem;
  text-align: center;
  border-radius: 0 0 7px 7px;
}

.code-example {
  background: #2d2d2d;
  color: #f8f8f2;
  padding: 1.5rem;
  border-radius: 4px;
  overflow-x: auto;
  margin-top: 1rem;
  font-family: 'Courier New', monospace;
  font-size: 1.3rem;
  line-height: 1.6;
}

@media (max-width: 768px) {
  .style-guide-nav {
    display: none;
  }
  .style-guide-content {
    margin-left: 0;
    padding: 2rem;
  }
}
</style>

<!-- Side Navigation -->
<nav class="style-guide-nav">
  <ul>
    <li><a href="#colors">Colors</a></li>
    <li><a href="#typography">Typography</a></li>
    <li><a href="#buttons">Buttons</a></li>
    <li><a href="#forms">Forms</a></li>
    <li><a href="#alerts">Alerts</a></li>
    <li><a href="#modals">Modals</a></li>
    <li><a href="#tabs">Tabs</a></li>
    <li><a href="#badges">Badges</a></li>
    <li><a href="#counts">Count Badges</a></li>
    <li><a href="#cards">Cards & Boxes</a></li>
    <li><a href="#progress">Progress Indicators</a></li>
    <li><a href="#navigation">Navigation</a></li>
    <li><a href="#chat">Chat</a></li>
    <li><a href="#calendar">Calendar</a></li>
    <li><a href="#documents">Document Lists</a></li>
    <li><a href="#shoppingcart">Cart</a></li>
    <li><a href="#footer">Footer</a></li>
  </ul>
</nav>

<div class="style-guide-content">
  <div class="container-fluid">
    <h1 class="mb-3">APU eCampus Style Guide</h1>
    <p class="lead mb-5">A comprehensive guide to all reusable design components in the eCampus system.</p>
    <p class="mb-5">Last Updated: April 2026</p>

    <!-- ============================================ -->
    <!-- COLORS SECTION -->
    <!-- ============================================ -->
