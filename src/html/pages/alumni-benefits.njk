{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/alumni-network.html" class="shortcut-item">
          <span><i class="fa-regular fa-user-group"></i></span>
          <p>Alumni Network</p>
        </a>
        <a href="/alumni-events.html" class="shortcut-item">
          <span><i class="fa-regular fa-calendar-check"></i></span>
          <p>Alumni Events</p>
        </a>
        <a href="/alumni-benefits.html" class="shortcut-item">
          <span><i class="fa-regular fa-award"></i></span>
          <p>Alumni Benefits</p>
        </a>
        <a href="/get-involved.html" class="shortcut-item">
          <span><i class="fa-regular fa-handshake"></i></span>
          <p>Get Involved</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Alumni Benefits</h1>
        <p class="lead mb-4">Explore exclusive benefits and discounts available to alumni.</p>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Career Services</h3>
              <p>Lifetime access to career support services.</p>
              <ul>
                <li>Job board access</li>
                <li>Resume review services</li>
                <li>Career counseling</li>
                <li>Professional development workshops</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Access Services</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Continuing Education</h3>
              <p>Special rates on continuing education and professional development.</p>
              <ul>
                <li>20% discount on certificate programs</li>
                <li>15% discount on graduate courses</li>
                <li>Free audit privileges</li>
                <li>Professional development courses</li>
              </ul>
              <a href="#" class="btn-main btn-sm">View Courses</a>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Library Access</h3>
              <p>Access to university library resources.</p>
              <ul>
                <li>Online database access</li>
                <li>E-books and journals</li>
                <li>Research assistance</li>
                <li>Digital archives</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Access Library</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Discounts & Services</h3>
              <ul>
                <li>Alumni email address for life</li>
                <li>Campus bookstore discounts</li>
                <li>Fitness center access</li>
                <li>Insurance discounts</li>
                <li>Rental car discounts</li>
                <li>Hotel and travel discounts</li>
              </ul>
              <a href="#" class="btn-main btn-sm">View All Benefits</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
