{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/faq.html" class="shortcut-item">
          <span><i class="fa-regular fa-circle-question"></i></span>
          <p>FAQ</p>
        </a>
        <a href="/technical-support.html" class="shortcut-item">
          <span><i class="fa-regular fa-headset"></i></span>
          <p>Technical Support</p>
        </a>
        <a href="/live-chat.html" class="shortcut-item">
          <span><i class="fa-regular fa-messages"></i></span>
          <p>Live Chat</p>
        </a>
        <a href="/contact-us.html" class="shortcut-item">
          <span><i class="fa-regular fa-envelope"></i></span>
          <p>Contact Us</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Help & Resources</h1>
        <p class="lead mb-4">Find answers to your questions and access support services.</p>

        <div class="row">
          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3"><i class="fa-regular fa-circle-question"></i> FAQ</h3>
              <p>Browse frequently asked questions and find quick answers to common inquiries.</p>
              <a href="#" class="btn-main btn-sm">View FAQ</a>
            </div>
          </div>

          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3"><i class="fa-regular fa-headset"></i> Technical Support</h3>
              <p>Get help with technical issues, login problems, and system access.</p>
              <a href="#" class="btn-main btn-sm">Contact Support</a>
            </div>
          </div>

          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3"><i class="fa-regular fa-comments"></i> Live Chat</h3>
              <p>Chat with a support representative for immediate assistance.</p>
              <a href="#" class="btn-main btn-sm">Start Chat</a>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Student Resources</h3>
              <ul>
                <li><a href="#" class="text-primary">Student Handbook</a></li>
                <li><a href="#" class="text-primary">Academic Calendar</a></li>
                <li><a href="#" class="text-primary">Course Catalog</a></li>
                <li><a href="#" class="text-primary">Campus Map</a></li>
                <li><a href="#" class="text-primary">Important Contacts</a></li>
              </ul>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Technical Resources</h3>
              <ul>
                <li><a href="#" class="text-primary">System Requirements</a></li>
                <li><a href="#" class="text-primary">Browser Compatibility</a></li>
                <li><a href="#" class="text-primary">Login Troubleshooting</a></li>
                <li><a href="#" class="text-primary">Video Tutorials</a></li>
                <li><a href="#" class="text-primary">Platform Guides</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <div class="white-box">
              <h3 class="h3 mb-3">Contact Information</h3>
              <div class="row">
                <div class="col-md-4">
                  <p><strong>Student Services</strong><br>
                  Phone: 1-800-555-1234<br>
                  Email: studentservices@apus.edu</p>
                </div>
                <div class="col-md-4">
                  <p><strong>Technical Support</strong><br>
                  Phone: 1-800-555-5678<br>
                  Email: techsupport@apus.edu</p>
                </div>
                <div class="col-md-4">
                  <p><strong>Office Hours</strong><br>
                  Monday - Friday: 8:00 AM - 8:00 PM EST<br>
                  Saturday - Sunday: 10:00 AM - 6:00 PM EST</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
