{% extends "layouts/registration-layout.njk" %}
{% import "partials/macros.njk" as buttons %}
{% set exitButtonText = "Exit Student Profile" %}
{% set exitButtonUrl = "/index.html" %}

{% block content %}
  <div class="container">
    <div class="row">
      <div class="shortcut-wrap">
        <div class="shortcut-rail">
          <a href="/student-profile.html" class="shortcut-item">
            <span><i class="fa-regular fa-user"></i></span>
            <p>Student Profile</p>
          </a>
          {# <a href="/student-organizations.html" class="shortcut-item">
            <span><i class="fa-regular fa-users-rectangle"></i></span>
            <p>Student Organizations</p>
          </a> #}
          <a href="/my-documents.html" class="shortcut-item active">
            <span><i class="fa-regular fa-file-lines"></i></span>
            <p>My Documents</p>
          </a>
          <a href="/wellness-resources.html" class="shortcut-item">
            <span><i class="fa-regular fa-heart"></i></span>
            <p>Wellness Resources</p>
          </a>
        </div>
      </div>
    </div>
    <div class="row row-main-layout">
      <div class="mb-5">
        <h1 class="mb-2">My Documents</h1>
        <p class="lead mb-4">Track and manage all your submitted documents and forms.</p>
      </div>
      <div class="right-divider mb-5">
        <p>Looking for general documants to download. Visit the Document Center.</p>
        <a class="btn-main" href="/forms-and-documents.html">Documents Center</a>
      </div>
    </div>
    <div class="row row-main-layout">
      <div class="mb-5">
        <!-- Document Progress Summary -->
        <div class="white-box mb-4">
          <h3 class="h3 mb-3">Document Status Overview</h3>
          <div class="row">
            <div class="col-md-4 mb-3 mb-md-0">
              <div class="document-stat stat-outstanding">
                <div class="stat-label-wrap stat-outstanding"><p class="stat-label red">Required</p></div>
                <div class="stat-icon required">
                  <i class="fa-solid fa-exclamation-circle"></i>
                </div>
                <div class="stat-info">
                  <p class="stat-number red">2</p>
                  
                </div>
              </div>
            </div>
            <div class="col-md-4 mb-3 mb-md-0">
              <div class="document-stat stat-pending">
              <div class="stat-label-wrap stat-pending"><p class="stat-label orange">Pending</p></div>
                <div class="stat-icon pending">
                  <i class="fa-solid fa-clock"></i>
                </div>
                <div class="stat-info">
                  <p class="stat-number orange">1</p>
                  {# <p class="stat-label">Pending Review</p> #}
                </div>
              </div>
            </div>
            <div class="col-md-4">
              <div class="document-stat stat-completed">
                <div class="stat-label-wrap stat-completed"><p class="stat-label green">Completed</p></div>
                <div class="stat-icon completed">
                  <i class="fa-solid fa-check-circle"></i>
                </div>
                <div class="stat-info">
                  <p class="stat-number green">6</p>
                  {# <p class="stat-label">Completed</p #}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Application Documents -->
        <div class="white-box mb-4">
          <h3 class="h3 mb-4"><i class="fa-regular fa-file-user"></i> Application Documents</h3>
          <div class="document-list">
            <div class="document-item green-completed">
              <div class="document-info">
                <span class="badge badge-completed mb-2"><i class="fa-solid fa-check-circle"></i> Completed</span>
                <h4 class="document-title">Student Application</h4>
                <p class="document-meta">Submitted: January 15, 2025</p>
              </div>
              <div class="document-actions">
                
                <a href="/view-application.html" class="btn-secondary btn-sm">View Application</a>
              </div>
            </div>

            <div class="document-item orange-pending">
              <div class="document-info">
                <span class="badge badge-pending mb-2" disabled><i class="fa-solid fa-clock"></i> Pending - Awaiting Delivery</span>
                <h4 class="document-title">Official Transcripts</h4>
                <p class="document-meta">Requested: January 20, 2025</p>
              </div>
              <div class="document-actions">
                {# <span class="badge badge-pending"><i class="fa-solid fa-clock"></i> Pending</span> #}
                <button class="btn-secondary btn-sm" disabled>Awaiting Delivery</button>                
              </div>
            </div>
          </div>
        </div>

        <!-- Identity Verification -->
        <div class="white-box mb-4">
          <h3 class="h3 mb-4"><i class="fa-regular fa-id-card"></i> Identity Verification</h3>
          <div class="document-list">
            <div class="document-item red-required">
              <div class="document-info">
                <span class="badge badge-required mb-2"><i class="fa-solid fa-exclamation-circle"></i> Required</span>
                <h4 class="document-title">Government-Issued Photo ID</h4>
                <p class="document-meta">Upload a clear copy of your driver's license, passport, or state ID</p>
              </div>
              <div class="document-actions">
                <a href="#" class="btn-main btn-sm" data-bs-toggle="modal" data-bs-target="#uploadIdModal">Upload ID</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Transfer Credits -->
        <div class="white-box mb-4">
          <h3 class="h3 mb-4"><i class="fa-regular fa-file-arrow-up"></i> Transfer Credits</h3>
          <div class="document-list">
            <div class="document-item red-required">
              <div class="document-info">
                <span class="badge badge-required mb-2"><i class="fa-solid fa-exclamation-circle"></i> Required</span>
                <h4 class="document-title">Transfer Credit Evaluation</h4>
                <p class="document-meta">Complete the transfer credit evaluation process to apply your previous college coursework</p>
              </div>
              <div class="document-actions">
                <a href="/transfer-credit.html" class="btn-main btn-sm">Begin Evaluation</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Orientation & Acknowledgments -->
        <div class="white-box mb-4">
          <h3 class="h3 mb-4"><i class="fa-regular fa-graduation-cap"></i> Student Acknowledgments</h3>
          <div class="document-list">
            <div class="document-item green-completed">
              <div class="document-info">
                <span class="badge badge-completed mb-2"><i class="fa-solid fa-check-circle"></i> Completed</span>
                <h4 class="document-title">Student Enrollment Agreement</h4>
                <p class="document-meta">Completed: February 10, 2025</p>
              </div>
              <div class="document-actions">
                {# <span class="badge badge-completed"><i class="fa-solid fa-check-circle"></i> Completed</span> #}
                <a href="#" class="arrow-link arrow-link-sm" data-bs-toggle="modal" data-bs-target="#viewEnrollmentAgreementModal">View Document</a>
              </div>
            </div>

            <div class="document-item green-completed">
              <div class="document-info">
                <span class="badge badge-completed mb-2"><i class="fa-solid fa-check-circle"></i> Completed</span>
                <h4 class="document-title">Academic Policies Acknowledgment</h4>
                <p class="document-meta">Acknowledged: February 10, 2025</p>
              </div>
              <div class="document-actions">
                <a href="#" class="arrow-link arrow-link-sm" data-bs-toggle="modal" data-bs-target="#viewAcademicPoliciesModal">View Document</a>
              </div>
            </div>

            <div class="document-item green-completed">
              <div class="document-info">
                <span class="badge badge-completed mb-2"><i class="fa-solid fa-check-circle"></i> Completed</span>
                <h4 class="document-title">Census Survey</h4>
                <p class="document-meta">Acknowledged: February 10, 2025</p>
              </div>
              <div class="document-actions">
                <a href="#" class="arrow-link arrow-link-sm" data-bs-toggle="modal" data-bs-target="#viewCensusSurveyModal">View Document</a>
              </div>
            </div>

            <div class="document-item green-completed">
              <div class="document-info">
                <span class="badge badge-completed mb-2"><i class="fa-solid fa-check-circle"></i> Completed</span>
                <h4 class="document-title">Student Code of Conduct Agreement</h4>
                <p class="document-meta">Acknowledged: February 10, 2025</p>
              </div>
              <div class="document-actions">
                <a href="#" class="arrow-link arrow-link-sm" data-bs-toggle="modal" data-bs-target="#viewConductAgreementModal">View Document</a>
              </div>
            </div>

            <div class="document-item green-completed">
              <div class="document-info">
                <span class="badge badge-completed mb-2"><i class="fa-solid fa-check-circle"></i> Completed</span>
                <h4 class="document-title">FERPA Privacy Rights Acknowledgment</h4>
                <p class="document-meta">Acknowledged: February 10, 2025</p>
              </div>
              <div class="document-actions">
                <a href="#" class="arrow-link arrow-link-sm" data-bs-toggle="modal" data-bs-target="#viewFERPAModal">View Document</a>
              </div>
            </div>
          </div>
        </div>

        <!-- Financial Documents (Disabled for Applicant Stage) -->
        <div class="white-box mb-4 document-section-disabled">
          <h3 class="h3 mb-4"><i class="fa-regular fa-file-invoice-dollar"></i> Financial Documents</h3>

          <div class="alert-alt alert-exclamation alert-disabled mb-3">
            <i class="fa-solid fa-lock"></i>
            <div>
              <p class="mb-0"><strong><em>Financial documents will be available once you have been accepted and complete the pre-enrollment process.</em></strong></p>
            </div>
          </div>

          <div class="document-list">
            <div class="document-item document-item-disabled">
              <div class="document-info">
                <h4 class="document-title">FAFSA Submission</h4>
                <p class="document-meta">Available after acceptance</p>
              </div>
              <div class="document-actions">
                <span class="badge badge-disabled"><i class="fa-solid fa-lock"></i> Locked</span>
              </div>
            </div>

            <div class="document-item document-item-disabled">
              <div class="document-info">
                <h4 class="document-title">Enrollment Agreement</h4>
                <p class="document-meta">Available after acceptance</p>
              </div>
              <div class="document-actions">
                <span class="badge badge-disabled"><i class="fa-solid fa-lock"></i> Locked</span>
              </div>
            </div>

            <div class="document-item document-item-disabled">
              <div class="document-info">
                <h4 class="document-title">Financial Responsibility Statement</h4>
                <p class="document-meta">Available after acceptance</p>
              </div>
              <div class="document-actions">
                <span class="badge badge-disabled"><i class="fa-solid fa-lock"></i> Locked</span>
              </div>
            </div>
          </div>
        </div>
      </div>
        <div class="mb-5">
          <!-- Application Support -->
          {% include "partials/layout/advisor.njk" %}

          <!-- Calendar -->
          {# <div class="actions white-box">
              {% include "partials/layout/calendar.njk" %}
          </div> #}
        </div>
      </div>
    </div>
  </div>

  <!-- Upload ID Modal -->
  <div class="modal fade" id="uploadIdModal" tabindex="-1" aria-labelledby="uploadIdModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
          <h3 class="modal-title h3" id="uploadIdModalLabel">Upload Photo ID</h3>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="padding: 2rem 2.5rem;">
          <p class="mb-3">Please upload a clear, legible copy of a government-issued photo ID (driver's license, passport, or state ID).</p>

          <div class="upload-area mb-3">
            <div class="text-center p-5" style="border: 2px dashed #ccc; border-radius: 8px; background: #f5f5f5;">
              <i class="fa-solid fa-cloud-arrow-up" style="font-size: 4rem; color: #666; margin-bottom: 1rem;"></i>
              <p class="mb-2"><strong>Click to upload or drag and drop</strong></p>
              <p class="text-muted mb-0">PNG, JPG, or PDF (max 10MB)</p>
              <input type="file" class="d-none" id="idFileInput" accept=".png,.jpg,.jpeg,.pdf">
            </div>
          </div>

          <div class="alert alert-info mb-0">
            <i class="fa-solid fa-info-circle me-2"></i>
            Your ID will be securely stored and only used for verification purposes.
          </div>
        </div>
        <div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
          <button type="button" class="btn btn-main" style="min-width: 120px;">Upload ID</button>
        </div>
      </div>
    </div>
  </div>

  <!-- View Enrollment Agreement Modal -->
  <div class="modal fade" id="viewEnrollmentAgreementModal" tabindex="-1" aria-labelledby="viewEnrollmentAgreementModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
