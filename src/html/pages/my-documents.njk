              <li>I understand my financial responsibilities as a student</li>
              <li>I consent to receive electronic communications from the university</li>
            </ul>

            <div class="signature-section p-3" style="background: #f5f5f5; border-left: 4px solid #000;">
              <p class="mb-2"><strong>Electronic Signature:</strong> Jorge Martinez</p>
              <p class="mb-0"><strong>Date:</strong> February 10, 2025 at 2:30 PM</p>
            </div>
          </div>
        </div>
        <div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 120px;">Close</button>
          <button type="button" class="btn btn-main" style="min-width: 140px;"><i class="fa-solid fa-download me-2"></i>Download PDF</button>
        </div>
      </div>
    </div>
  </div>

