  <!-- View FERPA Modal -->
  <div class="modal fade" id="viewFERPAModal" tabindex="-1" aria-labelledby="viewFERPAModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content">
        <div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
          <h3 class="modal-title h3" id="viewFERPAModalLabel">FERPA Privacy Rights Acknowledgment</h3>
