          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" style="padding: 2rem 2.5rem; max-height: 60vh; overflow-y: auto;">
          <div class="document-view">
            <div class="alert alert-info mb-4">
              <i class="fa-solid fa-check-circle me-2"></i>
              <strong>Status:</strong> Completed on February 10, 2025
            </div>

            <h4 class="mb-3">Student Information</h4>
            <div class="mb-4">
              <p class="mb-2"><strong>Name:</strong> Jorge Martinez</p>
              <p class="mb-2"><strong>Student ID:</strong> 24768</p>
              <p class="mb-2"><strong>Email:</strong> jmartinez@student.apus.edu</p>
              <p class="mb-2"><strong>Program:</strong> Computer Science, B.S.</p>
            </div>

            <h4 class="mb-3">Agreement Terms</h4>
            <p>By signing this agreement, I acknowledge that:</p>
            <ul class="info-list mb-4">
              <li>I have read and understand the terms and conditions of enrollment</li>
