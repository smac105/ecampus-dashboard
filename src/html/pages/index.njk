{% extends "layouts/base.njk" %}

{% block content %}

<div class="container">

	{% include "partials/alerts.njk" %}

</div>
	{# Stage Switcher for Demo #}
	<div class="stage-switcher-container">
		<label for="stageSwitcher">Student Journey Stage:</label>
		<select id="stageSwitcher" class="stage-switcher">
			<option value="prospective">Prospective Student</option>
			<option value="applicant" selected>Applicant</option>
			<option value="accepted">Accepted Student</option>
			<option value="enrolled">Enrolled Student</option>
			<option value="returning">Returning Student</option>
			<option value="alumni">Alumni</option>
		</select>
	</div>

	{# Load all stage layouts with data attributes #}
	<div class="stage-container" data-stage="prospective">
		{% include "partials/stages/prospective.njk" %}
	</div>

	<div class="stage-container active" data-stage="applicant">
		{% include "partials/stages/applicant.njk" %}
	</div>

	<div class="stage-container" data-stage="accepted">
		{% include "partials/stages/accepted.njk" %}
	</div>

	<div class="stage-container" data-stage="enrolled">
		{% include "partials/stages/enrolled.njk" %}
	</div>

	<div class="stage-container" data-stage="returning">
		{% include "partials/stages/returning.njk" %}
	</div>

	<div class="stage-container" data-stage="alumni">
		{% include "partials/stages/alumni.njk" %}
	</div>

{% endblock %}
