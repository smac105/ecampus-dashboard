{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/academic-forms.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-pen"></i></span>
          <p>Academic Forms</p>
        </a>
        <a href="/financial-forms.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-invoice"></i></span>
          <p>Financial Forms</p>
        </a>
        <a href="/official-documents.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-certificate"></i></span>
          <p>Official Documents</p>
        </a>
        <a href="/student-handbook.html" class="shortcut-item">
          <span><i class="fa-regular fa-book-open"></i></span>
          <p>Student Handbook</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Official Documents</h1>
        <p class="lead mb-4">Request and download official academic documents.</p>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Transcripts</h3>
              <p>Request official or unofficial transcripts.</p>
              <ul>
                <li>Official transcripts sent to institutions</li>
                <li>Unofficial transcripts for personal use</li>
                <li>Electronic or paper delivery</li>
                <li>Processing time: 3-5 business days</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Request Transcript</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Enrollment Verification</h3>
              <p>Verify your enrollment status for loans, insurance, or employment.</p>
              <ul>
                <li>Current enrollment verification</li>
                <li>Past enrollment verification</li>
                <li>Full-time/Part-time status</li>
                <li>Instant verification available</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Request Verification</a>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Degree Verification</h3>
              <p>Request verification of your degree completion.</p>
              <ul>
                <li>Degree conferral verification</li>
                <li>Graduation date confirmation</li>
                <li>Major and honors verification</li>
                <li>Electronic or paper delivery</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Request Verification</a>
            </div>
          </div>

          <div class="col-md-6 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Diploma Request</h3>
              <p>Order replacement diplomas or additional copies.</p>
              <ul>
                <li>Replacement for lost/damaged diplomas</li>
                <li>Additional copies</li>
                <li>Name change on diploma</li>
                <li>Various frame options available</li>
              </ul>
              <a href="#" class="btn-main btn-sm">Order Diploma</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
