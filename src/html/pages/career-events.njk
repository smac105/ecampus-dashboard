{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/job-search.html" class="shortcut-item">
          <span><i class="fa-regular fa-magnifying-glass"></i></span>
          <p>Job Search</p>
        </a>
        <a href="/resume-builder.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-user"></i></span>
          <p>Resume Builder</p>
        </a>
        <a href="/career-counseling.html" class="shortcut-item">
          <span><i class="fa-regular fa-comments"></i></span>
          <p>Career Counseling</p>
        </a>
        <a href="/career-events.html" class="shortcut-item">
          <span><i class="fa-regular fa-calendar-days"></i></span>
          <p>Career Events</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Career Events</h1>
        <p class="lead mb-4">Attend career fairs, workshops, and networking events.</p>

        <div class="row">
          <div class="col-12 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Upcoming Events</h3>

              <div class="mb-4">
                <h4 class="h4">Virtual Career Fair</h4>
                <p><strong>Date:</strong> March 15, 2025 | 10:00 AM - 4:00 PM EST</p>
                <p>Connect with employers from various industries seeking to hire graduates.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>

              <div class="mb-4">
                <h4 class="h4">Resume Writing Workshop</h4>
                <p><strong>Date:</strong> March 20, 2025 | 2:00 PM - 3:30 PM EST</p>
                <p>Learn how to create a compelling resume that gets noticed by employers.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>

              <div class="mb-4">
                <h4 class="h4">Interview Skills Seminar</h4>
                <p><strong>Date:</strong> March 25, 2025 | 1:00 PM - 2:30 PM EST</p>
                <p>Master interview techniques and learn how to answer tough questions.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>

              <div class="mb-4">
                <h4 class="h4">Professional Networking Mixer</h4>
                <p><strong>Date:</strong> April 5, 2025 | 6:00 PM - 8:00 PM EST</p>
                <p>Network with alumni, employers, and fellow students in a casual setting.</p>
                <a href="#" class="btn-main btn-sm">Register</a>
              </div>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <div class="white-box">
              <h3 class="h3 mb-3">Past Events</h3>
              <p>View recordings and materials from previous career events.</p>
              <a href="#" class="btn-main btn-sm">View Archive</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
