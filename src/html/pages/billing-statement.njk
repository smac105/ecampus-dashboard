{% extends "layouts/base.njk" %}

{% block content %}
  <div class="row">
    <div class="shortcut-wrap">
      <div class="shortcut-rail">
        <a href="/tuition-and-fees.html" class="shortcut-item">
          <span><i class="fa-regular fa-money-bill-wave"></i></span>
          <p>Tuition & Fees</p>
        </a>
        <a href="/financial-aid.html" class="shortcut-item">
          <span><i class="fa-regular fa-hand-holding-dollar"></i></span>
          <p>Financial Aid</p>
        </a>
        <a href="/payment-plans.html" class="shortcut-item">
          <span><i class="fa-regular fa-credit-card"></i></span>
          <p>Payment Plans</p>
        </a>
        <a href="/billing-statement.html" class="shortcut-item">
          <span><i class="fa-regular fa-file-invoice-dollar"></i></span>
          <p>Billing Statement</p>
        </a>
      </div>
    </div>
  </div>

  <div class="row">
    <div class="col-12">
      <div class="white-box mb-5">
        <h1 class="h1 mb-4">Billing Statement</h1>
        <p class="lead mb-4">View and download your billing statements.</p>

        <div class="row">
          <div class="col-md-8 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Current Statement</h3>
              <p><strong>Statement Date:</strong> February 1, 2025</p>
              <p><strong>Previous Balance:</strong> $4,250.00</p>
              <p><strong>Payments Received:</strong> -$0.00</p>
              <p><strong>New Charges:</strong> $0.00</p>
              <p class="h4"><strong>Current Balance:</strong> $4,250.00</p>
              <a href="#" class="btn-main btn-sm">Download Statement</a>
            </div>
          </div>

          <div class="col-md-4 mb-4">
            <div class="white-box">
              <h3 class="h3 mb-3">Quick Actions</h3>
              <ul>
                <li><a href="#" class="text-primary">Make Payment</a></li>
                <li><a href="#" class="text-primary">Set Up Auto-Pay</a></li>
                <li><a href="#" class="text-primary">View Payment Plan</a></li>
                <li><a href="#" class="text-primary">Contact Bursar</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="row">
          <div class="col-12">
            <div class="white-box">
              <h3 class="h3 mb-3">Statement History</h3>
              <p>View and download previous billing statements.</p>
              <ul>
                <li><a href="#" class="text-primary">January 2025 Statement</a></li>
                <li><a href="#" class="text-primary">December 2024 Statement</a></li>
                <li><a href="#" class="text-primary">November 2024 Statement</a></li>
                <li><a href="#" class="text-primary">View All Statements</a></li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
{% endblock %}
