<script>
// Toggle calendar view and handle tabs
document.addEventListener('DOMContentLoaded', function() {
  const toggleBtn = document.getElementById('calendarToggleBtn');
  const fullView = document.getElementById('calendarFullView');

  // Calendar expand/collapse
  if (toggleBtn && fullView) {
    toggleBtn.addEventListener('click', function() {
      const icon = this.querySelector('i');
      const isExpanded = fullView.style.display !== 'none';

      if (isExpanded) {
        // Collapse - hide full calendar
        fullView.style.display = 'none';
        icon.classList.remove('fa-chevron-up');
        icon.classList.add('fa-chevron-down');
      } else {
        // Expand - show full calendar
        fullView.style.display = 'block';
        icon.classList.remove('fa-chevron-down');
        icon.classList.add('fa-chevron-up');
      }
    });
  }

  // Calendar tab switching
  const calendarTabs = document.querySelectorAll('.calendar-tab-link');
  const schoolEventsList = document.getElementById('schoolEventsList');
  const studentEventsList = document.getElementById('studentEventsList');
  const schoolEventMarkers = document.querySelectorAll('.school-event');
  const studentEventMarkers = document.querySelectorAll('.student-event');

  if (calendarTabs.length > 0 && schoolEventsList && studentEventsList) {
    calendarTabs.forEach(tab => {
      tab.addEventListener('click', function(e) {
        e.preventDefault();

        // Update active tab
        calendarTabs.forEach(t => t.classList.remove('active'));
        this.classList.add('active');

        // Show/hide event lists and calendar markers
        const tabType = this.getAttribute('data-calendar-tab');
        if (tabType === 'school') {
          // Show school events
          schoolEventsList.style.display = 'flex';
          studentEventsList.style.display = 'none';

          // Show school markers, hide student markers
          schoolEventMarkers.forEach(marker => marker.style.display = 'grid');
          studentEventMarkers.forEach(marker => marker.style.display = 'none');
        } else if (tabType === 'student') {
          // Show student events
          schoolEventsList.style.display = 'none';
          studentEventsList.style.display = 'flex';

          // Hide school markers, show student markers
          schoolEventMarkers.forEach(marker => marker.style.display = 'none');
          studentEventMarkers.forEach(marker => marker.style.display = 'grid');
        }
      });
    });
  }
});
</script>

