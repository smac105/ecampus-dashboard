            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <span class="step-label">Review Cart</span>
        <div class="step-line"></div>
      </div>

      <div class="step-indicator" data-step="3">
