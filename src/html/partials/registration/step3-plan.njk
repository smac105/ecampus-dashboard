<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="mb-5">
        <h2 class="h2">Academic Plan Review</h2>
        <p class="lead">Review your academic plan and degree progress</p>
      </div>

      <div class="white-box mb-5">
        <h3 class="h3 mb-4">Degree Progress</h3>
        <div class="mb-3">
          <div class="d-flex justify-content-between mb-2">
            <span class="small-title gray-60">Credits Completed</span>
            <span class="h4 mb-0">89 / 120</span>
          </div>
          <div class="progress" style="height: 10px;">
            <div class="progress-bar" role="progressbar" style="width: 74%; background-color: var(--apu-blue);" aria-valuenow="74" aria-valuemin="0" aria-valuemax="100"></div>
          </div>
        </div>
      </div>

      <div class="white-box">
        <h3 class="h3 mb-4">Requirements Status</h3>
        <div class="mb-3">
          <div class="white-box d-flex align-items-center justify-content-between" style="background: #80c34220; border: 2px solid #80c342;">
            <span class="h4 mb-0" style="color: #80c342;">General Education</span>
            <span class="small-title" style="color: #80c342;">Complete</span>
          </div>
        </div>
        <div class="mb-3">
          <div class="white-box d-flex align-items-center justify-content-between" style="background: #F88A0020; border: 2px solid #F88A00;">
            <span class="h4 mb-0" style="color: #F88A00;">Major Requirements</span>
            <span class="small-title" style="color: #F88A00;">In Progress (75%)</span>
          </div>
        </div>
        <div class="mb-0">
          <div class="white-box d-flex align-items-center justify-content-between" style="background: #f4f4f4; border: 2px solid #d2d2d2;">
            <span class="h4 mb-0" style="color: #6d6d6d;">Electives</span>
            <span class="small-title" style="color: #6d6d6d;">Not Started</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
