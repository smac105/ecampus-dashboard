<div class="collapse" id="collapseProfile">
	<div class="card card-body menu">
		<div class="profile-dropdown-wrap">
			<div class="profile-header-section">
				<div class="profile-image-wrap">
					<div class="profile">
						<p class="big-initial">J</p>
					</div>
				</div>
				<div class="profile-info-section">
					<h3 class="profile-name mb-1">Jorge Martinez</h3>
					<p class="profile-detail mb-1"><strong>Student ID:</strong> 24768</p>
					<p class="profile-detail mb-1"><strong>Major:</strong> Computer Science</p>
					<p class="profile-detail mb-0"><strong>Expected Graduation:</strong> May 2026</p>
				</div>
			</div>
			<div class="profile-actions">
				<a href="/student-profile.html" class="btn-main btn-sm mb-2">
					{# <i class="fa-regular fa-user-pen"></i> #}Edit Profile
				</a>
				<a href="#" class="btn-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#shareContactModal">
					{# <i class="fa-regular fa-share-nodes"></i>  #}Share Contact Info
				</a>
			</div>
		</div>
