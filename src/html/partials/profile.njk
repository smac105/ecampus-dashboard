<!-- Share Contact Info Modal -->
<div class="modal fade" id="shareContactModal" tabindex="-1" aria-labelledby="shareContactModalLabel" aria-hidden="true">
	<div class="modal-dialog modal-dialog-centered">
		<div class="modal-content">
			<div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
				<h3 class="modal-title h3" id="shareContactModalLabel">Share Contact Information</h3>
				<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
			</div>
			<div class="modal-body" style="padding: 2rem 2.5rem;">
				<p>Choose what information you'd like to share with other students:</p>
				<div class="form-check mb-2">
					<input class="form-check-input" type="checkbox" value="" id="shareEmail" checked>
					<label class="form-check-label" for="shareEmail">
						Email Address
					</label>
				</div>
				<div class="form-check mb-2">
					<input class="form-check-input" type="checkbox" value="" id="sharePhone">
					<label class="form-check-label" for="sharePhone">
						Phone Number
					</label>
				</div>
				<div class="form-check mb-2">
					<input class="form-check-input" type="checkbox" value="" id="shareLinkedIn">
					<label class="form-check-label" for="shareLinkedIn">
						LinkedIn Profile
					</label>
				</div>
				<div class="form-check mb-3">
					<input class="form-check-input" type="checkbox" value="" id="shareMajor" checked>
					<label class="form-check-label" for="shareMajor">
						Major & Graduation Date
					</label>
				</div>
				<div class="mb-3">
					<label for="recipientEmail" class="form-label">Recipient Email:</label>
					<input type="email" class="form-control" id="recipientEmail" placeholder="student@university.edu">
				</div>
			</div>
			<div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
				<button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 140px;">Cancel</button>
				<button type="button" class="btn btn-main" data-bs-dismiss="modal" style="min-width: 140px;">Send Contact Info</button>
			</div>
		</div>
	</div>
</div>