{# =======================
   Overlay Navigation Menu
======================= #}
{% macro overlayMenu(items, quickLinks, currentPage) %}
<div class="overlay-menu" id="overlayMenu">
	<div class="overlay-menu-content">
		<div class="container">
			<!-- Search Bar (Mobile only) -->
			<div class="overlay-menu-search-mobile">
				{% include "partials/search-alt.njk" %}
			</div>

			<!-- Main Navigation Column (slides left on mobile) -->
			<div class="overlay-menu-sections">
				{% for item in items %}
					{% if not item.children %}
						<!-- Single Link Item (like Home) -->
						<div class="overlay-menu-item overlay-menu-item-single">
							<a href="{{ item.url }}" class="overlay-menu-link">
								<i class="fa-solid fa-{{ item.icon }}"></i>
								<span>{{ item.label }}</span>
							</a>
						</div>
					{% else %}
						<!-- Section with Dropdown -->
						<div class="overlay-menu-section" data-section="{{ item.slug }}">
							<button class="overlay-menu-title" data-section="{{ item.slug }}">
								<span class="title-content">
									<i class="fa-solid fa-{{ item.icon }}"></i> {{ item.label }}
								</span>
								<i class="fa-solid fa-chevron-right toggle-icon"></i>
							</button>
						</div>
					{% endif %}
				{% endfor %}
			</div>

			<!-- Dropdowns Container (outside of sections, not affected by slide-left transform) -->
			<div class="overlay-menu-dropdowns">
				{% for item in items %}
					{% if item.children %}
						<div class="overlay-menu-dropdown" data-dropdown="{{ item.slug }}">
							<button class="dropdown-back-button">
								<i class="fa-solid fa-arrow-left"></i>
								<span>Back</span>
							</button>
							<a href="{{ item.url }}" class="dropdown-overview-link">
								<i class="fa-solid fa-{{ item.icon }}"></i> {{ item.label }}
							</a>
							{% if item.description %}
								<p class="dropdown-description">{{ item.description }}</p>
							{% endif %}
							<ul class="overlay-menu-links">
								{% for column in item.children %}
									{% for link in column.links %}
										<li><a href="{{ link.url }}">{{ link.label }}</a></li>
									{% endfor %}
								{% endfor %}
							</ul>
						</div>
					{% endif %}
				{% endfor %}
			</div>

			<!-- Quick Links Sidebar -->
			{% if quickLinks %}
			<div class="overlay-menu-sidebar">
				<h4 class="overlay-sidebar-title">Quick Links</h4>
				<ul class="overlay-sidebar-links">
					{% for link in quickLinks %}
						<li><a href="{{ link.url }}"><i class="fa-solid fa-{{ link.icon }}"></i> {{ link.label }}</a></li>
					{% endfor %}
				</ul>
				<div class="right-ql-gradient"></div>
				<div class="left-ql-gradient"></div>
			</div>
			{% endif %}
		</div>
	</div>
</div>
{% endmacro %}

{# =======================
   Banner Section
======================= #}
{% macro banner(title, subtitle="", image="", showButton=false, buttonText="", buttonUrl="#") %}
  <section class="banner" style="{% if image %}background-image: url('{{ image }}');{% endif %}">
    <div class="banner-content">
      <h1>{{ title }}</h1>
      {% if subtitle %}
        <p>{{ subtitle }}</p>
      {% endif %}
      {% if showButton %}
        {{ button(buttonText, buttonUrl, "secondary") }}
      {% endif %}
    </div>
  </section>
{% endmacro %}


{# =======================
   Class Card
======================= #}
{% macro classCard(class) %}
  {# Check if this is an enrolled class (has currentGrade) or a registration class (has inStock) #}
  {% if class.currentGrade %}
    {# Determine grade color class based on letter grade #}
    {% set gradeColor = "grade-green" %}
    {% set gradeLetter = class.currentGrade | first %}
    {% if gradeLetter == "B" %}
      {% set gradeColor = "grade-yellow" %}
    {% elif gradeLetter == "C" %}
      {% set gradeColor = "grade-orange" %}
    {% elif gradeLetter == "D" or gradeLetter == "F" %}
      {% set gradeColor = "grade-red" %}
    {% endif %}

    {# Enrolled Class Card #}
    <div class="class-card enrolled-class">
      <div>
        <p class="class-title">{{ class.courseCode }} - {{ class.courseName }}</p>
        <p class="small-title gray-60 mb-2">{{ class.instructor }}</p>
        <div class="d-flex align-items-center gap-3 mb-2">
          <span class="badge {{ gradeColor }}">Grade: {{ class.currentGrade }}</span>
        </div>
        <div class="progress" style="height: 5px;">
          <div class="progress-bar {{ gradeColor }}" role="progressbar" style="width: {{ class.progress }}%;" aria-valuenow="{{ class.progress }}" aria-valuemin="0" aria-valuemax="100"></div>
        </div>
        <p class="small-title gray-60 mt-1 mb-0">{{ class.progress }}% Complete</p>
      </div>
      <div class="btn-wrap-sm btn-class-right">
        <a href="{{ class.classroomUrl }}" class="btn-main btn-sm" aria-label="Enter Classroom for {{ class.courseName }}">Enter Classroom</a>
      </div>
    </div>
  {% else %}
    {# Registration Class Card #}
    <div class="class-card{% if not class.inStock %} class-full{% endif %}">
      <div>
        <form>
          <input type="checkbox" name="">
        </form>
      </div>
      <div>
        <p class="class-title">{{ class.name }} - <span class="credits">{{ class.credits }} Credits</span></p>
      </div>

      {% if not class.inStock %}
          <div class="closed">
            <p class="white mb-0">Course Full</p>
          </div>
         <div class="btn-wrap-sm btn-class-right">
          <p>Registration Closed</p>
          </div>
      {% else %}
          <div class="open">
            <p class="white mb-0">Course Open</p>
          </div>
          <div class="btn-wrap-sm btn-class-right">
            <a href="#" class="btn-main btn-sm" aria-label="Register">Register</a>
          </div>
      {% endif %}
    </div>
  {% endif %}
{% endmacro %}

{# =======================
   Product Card
======================= #}
{% macro productCard(product) %}
<div class="product-card{% if not product.inStock %} out-of-stock{% endif %}">
    {# <img src="{{ product.image }}" alt="{{ product.name }}"> #}
    <h3>{{ product.name }}</h3>
    <p>{{ product.description }}</p>
    <span class="price">${{ product.price }} Credits</span>
    {% if not product.inStock %}
        <span class="badge">Sold Out</span>
    {% endif %}
</div>
{% endmacro %}

{# =======================
   Card Grid
======================= #}
{% macro cardGrid(items, renderCard) %}
<div class="product-grid">
    {% for item in items %}
        {{ renderCard(item) }}
    {% endfor %}
</div>
{% endmacro %}

{# =======================
  Images
======================= #}
{% macro image(src, alt="", className="", width="", height="", lazy=true, srcset="") %}
  {# Ensure the base path — you can modify this for your build setup (e.g., /assets/images/) #}
  {% set basePath = "./images/" %}
  {% set fullSrc = basePath + src %}

  <img
    src="{{ fullSrc }}"
    alt="{{ alt | escape }}"
    {% if className %}class="{{ className }}"{% endif %}
    {% if width %}width="{{ width }}"{% endif %}
    {% if height %}height="{{ height }}"{% endif %}
    {% if lazy %}loading="lazy"{% endif %}
    {% if srcset %}srcset="{{ srcset }}"{% endif %}
  >
{% endmacro %}

{# =======================
   Shortcut Rail
======================= #}
{% macro shortcutRail(items, renderCard) %}
<div class="product-grid">
    {% for item in items %}
        {{ renderCard(item) }}
    {% endfor %}
</div>
{% endmacro %}

