{# =======================
   Buttons
======================= #}
{% macro button(label, url="#", type="primary", isDisabled=false) %}
  <a href="{{ url }}"
     class="btn-main btn-{{ type }}{% if isDisabled %} disabled{% endif %}"
     {% if isDisabled %}aria-disabled="true"{% endif %}>
    {{ label }}
  </a>
{% endmacro %}

{% macro linkarrow(text, class, url, arialabel) %}
  <a href="{{ url }}" class="small-link {{ class }}" aria-label="{{ arialabel }}">
    {{ text }}
  </a>
{% endmacro %}

{% macro buttonmain(text, url='#') %}
  <a href="{{ url }}" class="btn-main">
    {{ text }}
  </a>
{% endmacro %}

{# =======================
  Top Navigation Menu
======================= #}
{% macro navTop(tops, currentPage) %}
  <nav id="sidebarMenuSmall" class="top-nav-wrap">
    <ul id="topmenu" class="mb-0">
      {% for top in tops %}
      <li class="{{ 'active' if top.slug == currentPage }}">
        <a href="{{ top.url }}" data-slug="{{ top.slug }}">
          <span class="top-wrap"><i class="{{ top.img }}"></i></span>
        </a>
        {% if top.slug == 'cart' %}
          <span class="count" data-cart-badge style="display: none;">0</span>
        {% elif top.count %}
          <span class="count {{ top.slug }}">{{ top.count }}</span>
        {% endif %}
      </li>
      {% endfor %}
      {# <li class="{{ 'active' if top.slug == currentPage }}">
        <a href="#collapseExample" data-bs-toggle="collapse" aria-expanded="false" aria-controls="collapseExample"><span class="top-wrap"><i class="fa-solid fa-grid"></i></span></a>
      </li> #}
    </ul>
  </nav>
{% endmacro %}

{# =======================
  App Menu
======================= #}

{% macro navApps(apps, currentPage) %}
  <nav class="">
    <ul class="app-menu-list mb-0">
      {% for app in apps %}
      <li class="app-menu-item {{ 'active' if app.slug == currentPage }}">
        <a href="{{ app.url }}">
        <span class="app-menu-app"><i class="{{ app.img }}"></i></span>
        <p class="small-title mb-0">{{ app.label }}</p>
        </a>
      </li>
      {% endfor %}
    </ul>
  </nav>
{% endmacro %}

{# =======================
  Icon Navigation Menu
======================= #}
{% macro navIcon(icons, currentPage) %}
  <nav id="sidebarMenuSmall" class="icon-nav-wrap">
    <ul id="iconmenu">
      {% for icon in icons %}
        <li class="{{ 'active' if icon.slug == currentPage }}">
          <a href="{{ icon.url }}"><span class="icon-wrap"><i class="{{ icon.img }}"></i></span><br>{{ icon.label }}</a>
        </li>
      {% endfor %}
    </ul>
</nav>
{% endmacro %}

