{% macro progress(label, value, max, color, displayType="raw") %}
  {# Normalize to a 0–1 fraction #}
{% set percent = value / max %}
<div class="progress-circle-wrap">
  {% if displayType == "percent" %}
  <div class="progress-circle" style="--value: {{ percent }}; --color: {{ color }};" data-label="{{ label }}">
    <div class="progress-inner">
    {# {% if displayType == "percent" %} #}
      <span class="gauge-value">{{ (percent * 100) | round }}%</span>
    </div>
  </div>
  {% if label %}
    <p class="gauge-label">{{ label }}</p>
  {% endif %}
{% else %}
  <div class="progress-circle circle-adj" style="--value: {{ percent }}; --color: {{ color }};" data-label="{{ label }}">
    <div class="progress-inner">
    {# {% if displayType == "percent" %} #}
      <span class="gauge-value">{{ value }}</span>
    </div>
  </div>
  {% if label %}
    <p class="gauge-label">{{ label }}</p>
  {% endif %}
{% endif %}
</div>
{% endmacro %}

{% macro progressLine(label, value, max, color, displayType="raw") %}
  {% set percent = value / max %}

  <div class="progress-line-wrapper" data-label="{{ label }}">
    <div
      class="progress-line"
      style="--value: {{ percent }}; --color: {{ color }};"
    >
      <span class="progress-line__label" style="position: {{ percent }};">
        {% if displayType == "percent" %}
          {{ (percent * 100) | round }}%
        {% else %}
          {{ value }} / {{ max }}
        {% endif %}
      </span>
    </div>
  </div>
{% endmacro %}

