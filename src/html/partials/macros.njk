{# =======================
   Buttons
======================= #}
{% macro button(label, url="#", type="primary", isDisabled=false) %}
  <a href="{{ url }}" 
     class="btn-main btn-{{ type }}{% if isDisabled %} disabled{% endif %}" 
     {% if isDisabled %}aria-disabled="true"{% endif %}>
    {{ label }}
  </a>
{% endmacro %}

{# =======================
  Top Navigation Menu
======================= #}
{% macro navTop(tops, currentPage) %}
  <nav id="sidebarMenuSmall" class="top-nav-wrap">
    <ul id="topmenu" class="mb-0">
      {% for top in tops %}
      <li class="{{ 'active' if top.slug == currentPage }}">
        <a href="{{ top.url }}"><span class="top-wrap"><i class="{{ top.img }}"></i></span></a>
        {% if top.count %}<span class="count">{{ top.count }}</span>{% endif %}
      </li>
      {% endfor %}
      <li class="{{ 'active' if top.slug == currentPage }}">
        <a type="button" data-bs-toggle="collapse" data-bs-target="#collapseExample" data-bs-parent="topnav-group" aria-expanded="false" aria-controls="collapseExample"><span class="top-wrap"><i class="fa-solid fa-grid"></i></span></a>
      </li>
    </ul>
  </nav>
{% endmacro %}

{# =======================
  App Menu
======================= #}

{% macro navApps(apps, currentPage) %}
  <nav class="">
    <ul class="app-menu-list mb-0">
      {% for app in apps %}
      <li class="app-menu-item {{ 'active' if app.slug == currentPage }}">
        <a href="{{ app.url }}">
        <span class="app-menu-app"><i class="{{ app.img }}"></i></span>
        <p class="small-title mb-0">{{ app.label }}</p>
        </a>
      </li>
      {% endfor %}
    </ul>
  </nav>
{% endmacro %}

{# =======================
  Icon Navigation Menu
======================= #}
{% macro navIcon(icons, currentPage) %}
  <nav id="sidebarMenuSmall" class="icon-nav-wrap">
    <ul id="iconmenu">
      {% for icon in icons %}
        <li class="{{ 'active' if icon.slug == currentPage }}">
          <a href="{{ icon.url }}"><span class="icon-wrap"><i class="{{ icon.img }}"></i></span><br>{{ icon.label }}</a>
        </li>
      {% endfor %}
    </ul>
</nav>
{% endmacro %}

{# =======================
   Navigation Menu
======================= #}
{% macro navMenu(items, currentPage) %}
  <div>
<div id="mySidebar" class="dashboard-nav">
  {# <header>
    <a href="#!" class="menu-toggle"><i class="fas fa-x"></i></a>
    <a href="#" class="brand-logo"><i class="fas fa-anchor"></i> <span>BRAND</span></a>
  </header> #}
  {# <div class="nav-toggle-wrap">
    <a href="javascript:void(0)" class="closebtn" onclick="closeNav()"><i class="fa-solid fa-chevron-left"></i></a>
  </div> #}
  
  <ul class="icon-nav-wrap">
    <div class="nav-toggle-wrap">
      {# <a href="#!" class="menu-toggle"><i class="fa-solid fa-chevron-left"></i></a> #}
      <a class="closebtn" data-bs-toggle="offcanvas" href="#offcanvasExample" role="button" aria-controls="offcanvasExample"><i class="fa-solid fa-bars"></i></a>
    </div>
    {% for item in items %}
        <li class=" {{ 'active' if item.slug == currentPage }}">
          <a href="{{ item.url }}"  aria-label="{{ item.label }}"><i class="fa-regular fa-{{ item.icon }}"></i>
            <p>{{ item.label }}</p>
          </a>
        </li>
      {% endfor %}
  </ul>    
</div>


<div class="offcanvas offcanvas-lg offcanvas-start" tabindex="-1" id="offcanvasExample" aria-labelledby="offcanvasExampleLabel">
  <div class="offcanvas-header">
    <div class="sm-logo-main"> 
      <a href="index.html" aria-label="American Public University ECampus Home">
        {# {{ image("logo-apus-global-icon.svg", "", "img-logo-main main-logo") }} #}
        {% include "partials/apu-logo.njk" %}
      </a>
    </div>
    <button type="button" class="btn-new-close" data-bs-dismiss="offcanvas" aria-label="Close"><i class="fa-regular fa-xmark"></i></button>
  </div>
  <div class="offcanvas-body">
    <nav class="dashboard-nav-list">
      {% for item in items %}
        <li class="dashboard-nav-item {% if item.children %}dropdown{% endif %}">
          
          {# Regular link if no children #}
          {% if not item.children %}
            <a 
              class="{% if item.page == currentPage %}active{% endif %}" 
              aria-label="{{ item.label }}"
              href="{{ item.url }}">
              <i class="fa-regular fa-{{ item.icon }}"></i> {{ item.label }}
            </a>
          
          {# Dropdown OR Mega Menu #}
          {% else %}
            <a 
              class=" dropdown-toggle {% if item.page == currentPage %}active{% endif %}" 
              href="#" 
              id="dropdown-{{ loop.index }}"
              aria-label="{{ item.label }}" 
              role="button" 
              data-bs-toggle="dropdown" 
              aria-expanded="false">
              <i class="fa-regular fa-{{ item.icon }}"></i> {{ item.label }}
            </a>

            {# Mega Menu if item.mega is true #}
            {% if item.mega %}
              <div class="dropdown-menu collapse collapse-or" aria-labelledby="dropdown-{{ loop.index }}" data-bs-auto-close="outside">
                <div class="dropdown-columns">
                 {# <a 
                  class="dropdown-reverse-toggle {% if item.page == currentPage %}active{% endif %}" 
                  href="#" 
                  id="dropdown-{{ loop.index }}"
                  aria-label="{{ item.label }}" 
                  role="button" 
                  data-bs-toggle="dropdown" 
                  aria-expanded="false">
                  back
                </a> #}
                  {% for column in item.children %}
                    <div class="drop-col">
                      <ul class="list-unstyled">
                        {% for link in column.links %}
                          <li><a class="dropdown-item" aria-label="{{ link.label }}" href="{{ link.url }}">{{ link.label }}</a></li>
                        {% endfor %}
                      </ul>
                    </div>
                  {% endfor %}
                </div>
              </div>
            
            {# Standard Dropdown #}
            {% else %}
              <ul class="dropdown-menu" aria-labelledby="dropdown-{{ loop.index }}">
              {% for child in item.children %}
                <li>
                  <a 
                    class="dropdown-item {% if child.page == currentPage %}active{% endif %}" 
                    aria-label="{{ child.label }}"
                    href="{{ child.url }}"
                    data-bs-toggle="dropdown"
                    aria-expanded="false">
                    {{ child.label }}
                  </a>
                </li>
              {% endfor %}
              </ul>
          
            {% endif %}
          
          {% endif %}
        </li>
      {% endfor %}
      
    </nav>
  </div>
</div>
</div>
{% endmacro %}



