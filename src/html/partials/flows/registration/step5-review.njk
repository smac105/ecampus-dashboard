<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="mb-5">
        <h2 class="h2">Review Cart</h2>
        <p class="lead">Final review before proceeding to payment</p>
      </div>

      <div class="white-box mb-5">
        <h3 class="h3 mb-4">Summary</h3>
        <div class="mb-3">
          <div class="d-flex justify-content-between">
            <span class="small-title gray-60">Courses</span>
            <span class="h4 mb-0" id="reviewCoursesCount">0 courses</span>
          </div>
        </div>
        <div class="mb-3">
          <div class="d-flex justify-content-between">
            <span class="small-title gray-60">Total Credits</span>
            <span class="h4 mb-0" id="reviewCredits">0</span>
          </div>
        </div>
        <div class="mb-4">
          <div class="d-flex justify-content-between">
            <span class="small-title gray-60">Payment Method</span>
            <span class="h4 mb-0" id="reviewPaymentMethod">-</span>
          </div>
        </div>
        <div class="white-box gradient-bg">
          <div class="d-flex justify-content-between align-items-center">
            <span class="h3 mb-0">Total Amount</span>
            <span class="h2 mb-0" id="reviewTotal">$0.00</span>
          </div>
        </div>
      </div>

      <div class="alert" style="background: var(--apu-blue-alt); border: 2px solid var(--apu-blue); padding: 2rem;">
        <p class="small-title mb-0">
          <strong>Note:</strong> By proceeding, you acknowledge that you have reviewed your course selection and understand the refund policy.
        </p>
      </div>
    </div>
  </div>
</div>
