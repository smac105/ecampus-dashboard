{# Exit Confirmation Modal #}
<div class="modal fade" id="exitConfirmationModal" tabindex="-1" aria-labelledby="exitConfirmationModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
        <h3 class="modal-title h3" id="exitConfirmationModalLabel">Save Your Progress?</h3>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body" style="padding: 2rem 2.5rem;">
        <p class="lead mb-4">Your selected courses and registration progress will be saved to your cart.</p>
        <p class="small-title gray-60 mb-0">You can resume your registration anytime by clicking the cart icon in the top navigation.</p>
      </div>

      <div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 140px;">
          Stay Here
        </button>
        <button type="button" class="btn btn-main" id="confirmExitBtn" style="min-width: 140px;">
          Exit & Save
        </button>
      </div>
    </div>
  </div>
</div>
