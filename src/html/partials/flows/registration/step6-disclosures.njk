<div class="container-fluid">
  <div class="row">
    <div class="col-12">
      <div class="mb-5">
        <h2 class="h2">Review Disclosures</h2>
        <p class="lead">Please read and accept the following disclosures</p>
      </div>

      <div class="white-box mb-5">
        <label class="d-flex align-items-start mb-4">
          <input type="checkbox" id="disclosure1" class="mt-1 me-3" required>
          <div class="flex-fill">
            <p class="h4 mb-2">Academic Integrity Policy</p>
            <p class="small-title mb-0">I have read and agree to abide by the university's academic integrity policy.</p>
          </div>
        </label>

        <label class="d-flex align-items-start mb-4">
          <input type="checkbox" id="disclosure2" class="mt-1 me-3" required>
          <div class="flex-fill">
            <p class="h4 mb-2">Refund Policy</p>
            <p class="small-title mb-0">I understand the refund policy and deadline for dropping courses with a full refund.</p>
          </div>
        </label>

        <label class="d-flex align-items-start mb-4">
          <input type="checkbox" id="disclosure3" class="mt-1 me-3" required>
          <div class="flex-fill">
            <p class="h4 mb-2">Financial Responsibility</p>
            <p class="small-title mb-0">I acknowledge my financial responsibility for all registered courses.</p>
          </div>
        </label>

        <label class="d-flex align-items-start mb-0">
          <input type="checkbox" id="disclosure4" class="mt-1 me-3" required>
          <div class="flex-fill">
            <p class="h4 mb-2">Data Privacy</p>
            <p class="small-title mb-0">I consent to the collection and use of my data as described in the privacy policy.</p>
          </div>
        </label>
      </div>

      <div class="alert" style="background: var(--apu-yellow-alt); border: 2px solid var(--apu-yellow); padding: 2rem;">
        <p class="small-title mb-0"><strong>Important:</strong> All disclosures must be accepted to continue with registration.</p>
      </div>
    </div>
  </div>
</div>
