<div class="container">
  <div class="row">
    <div class="col-lg-6 mb-5">
      <div class="mb-5">
        <h2 class="h2">Payment Details</h2>
        <p class="lead">Enter your payment information</p>
      </div>

      <div class="white-box">
        <div id="paymentForm">
          <div class="mb-4">
            <label class="form-label h4">Cardholder Name</label>
            <input type="text" class="form-control form-control-lg" placeholder="John Doe">
          </div>

          <div class="mb-4">
            <label class="form-label h4">Card Number</label>
            <input type="text" class="form-control form-control-lg" placeholder="1234 5678 9012 3456">
          </div>

          <div class="row mb-4">
            <div class="col-md-6 mb-3 mb-md-0">
              <label class="form-label h4">Expiration Date</label>
              <input type="text" class="form-control form-control-lg" placeholder="MM/YY">
            </div>
            <div class="col-md-6">
              <label class="form-label h4">CVV</label>
              <input type="text" class="form-control form-control-lg" placeholder="123">
            </div>
          </div>

          <div class="white-box gradient-bg">
            <div class="d-flex justify-content-between align-items-center">
              <span class="h3 mb-0">Amount to Charge</span>
              <span class="h2 mb-0" id="paymentAmount">$0.00</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-6 mb-5">
      <div class="mb-5">
        <h2 class="h2">Shipping Address</h2>
        <p class="lead">Enter address for course materials</p>
      </div>

      <div class="white-box">
        <form id="shippingForm">
          <div class="mb-4">
            <label class="form-label h4">Full Name</label>
            <input type="text" class="form-control form-control-lg" placeholder="John Doe" required>
          </div>

          <div class="mb-4">
            <label class="form-label h4">Street Address</label>
            <input type="text" class="form-control form-control-lg" placeholder="123 Main St" required>
          </div>

          <div class="mb-4">
            <label class="form-label h4">Address Line 2</label>
            <input type="text" class="form-control form-control-lg" placeholder="Apt, Suite, Unit (optional)">
          </div>

          <div class="row mb-4">
            <div class="col-md-6 mb-3 mb-md-0">
              <label class="form-label h4">City</label>
              <input type="text" class="form-control form-control-lg" placeholder="Springfield" required>
            </div>
            <div class="col-md-6">
              <label class="form-label h4">State</label>
              <select class="form-select form-select-lg" required>
                <option value="">Select State</option>
                <option value="CA">California</option>
                <option value="NY">New York</option>
                <option value="TX">Texas</option>
                <option value="FL">Florida</option>
                <option value="IL">Illinois</option>
              </select>
            </div>
          </div>

          <div class="mb-4">
            <label class="form-label h4">ZIP Code</label>
            <input type="text" class="form-control form-control-lg" placeholder="12345" required>
          </div>

          <div class="mb-0">
            <label class="form-label h4">Phone Number</label>
            <input type="tel" class="form-control form-control-lg" placeholder="(555) 123-4567" required>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
