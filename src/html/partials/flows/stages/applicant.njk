<!-- Sticky Chat Button -->
<button class="chat-sticky-btn" id="chatStickyBtn" aria-label="Open chat">
  <i class="fa-solid fa-comment"></i>
</button>

<!-- Chat Window -->
<div class="chat-window" id="chatWindow">
  <div class="chat-window-header">
    <div>
      <h4 class="mb-0">Chat with Us</h4>
      <p class="chat-status mb-0">We're here to help!</p>
    </div>
    <button class="chat-close-btn" id="closeChatBtn" aria-label="Close chat">
      <i class="fa-solid fa-xmark"></i>
    </button>
  </div>
  <div class="chat-window-body">
    <div class="chat-message chat-message-agent">
      <div class="chat-message-content">
        <p class="mb-1"><strong>Support Team</strong></p>
        <p class="mb-0">Hi! How can we help you today?</p>
      </div>
    </div>
  </div>
  <div class="chat-window-footer">
    <input type="text" class="chat-input" placeholder="Type your message..." aria-label="Chat message">
    <button class="chat-send-btn" aria-label="Send message">
      <i class="fa-solid fa-paper-plane"></i>
    </button>
  </div>
</div>

<script>
// Chat window toggle
document.addEventListener('DOMContentLoaded', function() {
  const chatBtn = document.getElementById('chatStickyBtn');
  const chatWindow = document.getElementById('chatWindow');
  const closeBtn = document.getElementById('closeChatBtn');

  if (chatBtn && chatWindow) {
    chatBtn.addEventListener('click', function() {
      chatWindow.classList.add('show');
      chatBtn.style.display = 'none';
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        chatWindow.classList.remove('show');
        chatBtn.style.display = 'flex';
      });
    }
  }
});
</script>