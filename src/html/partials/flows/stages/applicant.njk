{% import "partials/macros.njk" as buttons %}

{# Applicant Student Stage #}
<div class="container">
<!-- Outage Notification -->
<div class="alert-outage" id="outageAlert">
	<button class="alert-close-btn alert-close-btn-outage" id="closeOutageAlert" aria-label="Close alert">
		<i class="fa-solid fa-xmark"></i>
	</button>
	<div class="alert-outage-icon">
		<i class="fa-solid fa-triangle-exclamation"></i>
	</div>
	<div class="alert-outage-content">
		<h4 class="mb-1"><strong>System Maintenance Notice</strong></h4>
		<p class="mb-0">Our systems will be undergoing scheduled maintenance on Sunday, April 6th from 2:00 AM - 6:00 AM EST. Some services may be temporarily unavailable during this time.</p>
	</div>
</div>

<!-- Horizontal Progress Tracker -->
{% include "partials/ui/horizontal-progress-tracker.njk" %}

<div class="row row-main-layout">
	<div class="mb-5">
		<!-- Welcome Message -->
		<div class="intro-box">
			<h1>Congratulations Jorge! You're On Your Way to Being Enrolled.</h1>
			<p class="lead mb-0">Thank you for starting your education journey with APU! Complete the remaining steps below to start the enrollment process. Our admissions team is here to help if you have any questions as you continue to gather items needed in order to enroll before the next start date.</p>
		</div>
		<div class="alert-alt alert-required" id="transcriptAlert">
			<button class="alert-close-btn" id="closeTranscriptAlert" aria-label="Close alert">
				<i class="fa-solid fa-xmark"></i>
			</button>
			<div>
				<p class="next-step-badge small-title red">ACTION REQUIRED BEFORE ENROLLMENT CAN BEGIN!</p>
				<h3>Request Official Transcripts
					<i class="fa-solid fa-circle-info"
					   data-bs-toggle="popover"
					   data-bs-trigger="focus"
					   data-bs-placement="top"
					   data-bs-content="To complete your application, please submit official transcripts from all previously attended institutions. Transcripts can be sent electronically to transcripts@apus.edu or mailed to our admissions office."
					   tabindex="0"
					   role="button"
					   aria-label="More information about transcript requirements"
					   style="cursor: pointer; font-size: 2rem; margin-left: 0.5rem; color: #0581C0;"></i>
				</h3>
			</div>
			<div>
				<a href="#" {# target="_blank" #} class="btn-main btn-sm">Request Transcripts</a>
			</div>
		</div>

		<script>
		// Close alert functionality
		document.addEventListener('DOMContentLoaded', function() {
			// Transcript alert
			const closeBtn = document.getElementById('closeTranscriptAlert');
			const alert = document.getElementById('transcriptAlert');

			if (closeBtn && alert) {
				closeBtn.addEventListener('click', function() {
					alert.style.opacity = '0';
					alert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						alert.style.display = 'none';
					}, 300);
				});
			}

			// Outage alert
			const closeOutageBtn = document.getElementById('closeOutageAlert');
			const outageAlert = document.getElementById('outageAlert');

			if (closeOutageBtn && outageAlert) {
				closeOutageBtn.addEventListener('click', function() {
					outageAlert.style.opacity = '0';
					outageAlert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						outageAlert.style.display = 'none';
					}, 300);
				});
			}
		});
		</script>
		
		<!-- Enrollment To Do List - Tabbed Version -->
		{% include "partials/ui/enrollment-todo-tabs.njk" %}

	</div>

	<div class="mb-5">

		<!-- Document Center Info -->
