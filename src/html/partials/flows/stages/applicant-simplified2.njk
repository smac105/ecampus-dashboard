<!-- Upload ID Modal -->
<div class="modal fade" id="uploadIdModal" tabindex="-1" aria-labelledby="uploadIdModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
        <h3 class="modal-title h3" id="uploadIdModalLabel">Upload Photo ID</h3>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 2rem 2.5rem;">
        <p class="mb-3">Please upload a clear, legible copy of a government-issued photo ID (driver's license, passport, or state ID).</p>

        <div class="upload-area mb-3">
          <div class="text-center p-5" style="border: 2px dashed #ccc; border-radius: 8px; background: #f5f5f5;">
            <i class="fa-solid fa-cloud-arrow-up" style="font-size: 4rem; color: #666; margin-bottom: 1rem;"></i>
            <p class="mb-2"><strong>Click to upload or drag and drop</strong></p>
            <p class="text-muted mb-0">PNG, JPG, or PDF (max 10MB)</p>
            <input type="file" class="d-none" id="idFileInput" accept=".png,.jpg,.jpeg,.pdf">
          </div>
        </div>

        <div class="alert alert-info mb-0">
          <i class="fa-solid fa-info-circle me-2"></i>
          Your ID will be securely stored and only used for verification purposes.
        </div>
      </div>
      <div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
        <button type="button" class="btn btn-main" style="min-width: 120px;">Upload ID</button>
      </div>
    </div>
  </div>
</div>

<!-- Opt Out Transfer Credits Modal -->
<div class="modal fade" id="optOutTransferCreditsModal" tabindex="-1" aria-labelledby="optOutTransferCreditsModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
        <h3 class="modal-title h3" id="optOutTransferCreditsModalLabel">Opt Out of Transfer Credit Evaluation</h3>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 2rem 2.5rem;">
        <p class="mb-3">You previously indicated that you have college credits from another institution that may be transferable to APUS.</p>

        <div class="alert alert-warning mb-3">
          <i class="fa-solid fa-exclamation-triangle me-2"></i>
          <strong>Important:</strong> If you opt out of the transfer credit evaluation process, any previously earned college credits will not be evaluated or applied toward your degree requirements at APUS.
        </div>

        <p class="mb-3"><strong>By opting out, you understand that:</strong></p>
        <ul class="mb-3">
          <li>You will not receive credit for courses completed at other institutions</li>
          <li>You may need to retake courses you have already completed</li>
          <li>Your time to degree completion may be longer</li>
          <li>You can request a transfer credit evaluation later, but processing times may vary</li>
        </ul>

        <p class="mb-0">Are you sure you want to opt out of the transfer credit evaluation?</p>
      </div>
      <div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 140px;">Cancel</button>
        <button type="button" class="btn btn-main" id="confirmOptOutBtn" style="min-width: 140px;">Yes, Opt Out</button>
      </div>
    </div>
  </div>
</div>

<!-- Change Program Modal -->
<div class="modal fade" id="changeProgramModal" tabindex="-1" aria-labelledby="changeProgramModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header" style="border-bottom: 1px solid #d9d9d9; padding: 2rem 2.5rem 1.5rem;">
        <h3 class="modal-title h3" id="changeProgramModalLabel">Change Your Program</h3>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" style="padding: 2rem 2.5rem;">
        <div class="alert-blue mb-4">
          <p class="mb-0"><i class="fa-solid fa-info-circle me-2"></i> <strong>Note:</strong> Changing your program may affect your enrollment timeline and transfer credit evaluation. Please review your selection carefully.</p>
        </div>

        <form id="changeProgramForm">
          <div class="mb-4">
            <label for="currentProgram" class="form-label"><strong>Current Program</strong></label>
            <input type="text" class="form-control" id="currentProgram" value="Bachelor of Science - Computer Science" disabled>
          </div>

          <div class="mb-4">
            <label for="newProgram" class="form-label"><strong>Select New Program</strong> <span class="red">*</span></label>
            <select class="form-select" id="newProgram" required>
              <option value="" selected>Choose a program...</option>
              <optgroup label="Undergraduate Programs">
                <option value="ba-business">Bachelor of Arts - Business Administration</option>
                <option value="bs-cybersecurity">Bachelor of Science - Cybersecurity</option>
                <option value="bs-healthcare">Bachelor of Science - Healthcare Management</option>
                <option value="bs-psychology">Bachelor of Science - Psychology</option>
                <option value="bs-criminal-justice">Bachelor of Science - Criminal Justice</option>
              </optgroup>
              <optgroup label="Graduate Programs">
                <option value="mba">Master of Business Administration (MBA)</option>
                <option value="ms-cybersecurity">Master of Science - Cybersecurity</option>
                <option value="ms-it">Master of Science - Information Technology</option>
                <option value="ma-education">Master of Arts - Education</option>
              </optgroup>
            </select>
          </div>

          <div class="mb-4">
            <label for="reasonForChange" class="form-label"><strong>Reason for Change</strong> <span class="red">*</span></label>
            <select class="form-select" id="reasonForChange" required>
              <option value="" selected>Select a reason...</option>
              <option value="career-goals">Career goals have changed</option>
              <option value="interest">Different area of interest</option>
              <option value="prerequisites">Cannot meet program prerequisites</option>
              <option value="transfer-credits">Transfer credits better aligned with another program</option>
              <option value="other">Other</option>
            </select>
          </div>

          <div class="mb-4" id="otherReasonField" style="display: none;">
            <label for="otherReason" class="form-label"><strong>Please specify</strong></label>
            <textarea class="form-control" id="otherReason" rows="3" placeholder="Please provide details..."></textarea>
          </div>

          <div class="mb-4">
            <label for="additionalComments" class="form-label"><strong>Additional Comments</strong> (Optional)</label>
            <textarea class="form-control" id="additionalComments" rows="3" placeholder="Any additional information you'd like to share..."></textarea>
          </div>

          <div class="alert alert-warning mb-0">
            <i class="fa-solid fa-exclamation-triangle me-2"></i>
            <strong>Important:</strong> Your program change request will be reviewed by an academic advisor. You will receive a confirmation email within 2-3 business days.
          </div>
        </form>
      </div>
      <div class="modal-footer" style="border-top: 1px solid #d9d9d9; padding: 1.5rem 2.5rem 2rem; gap: 1rem;">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="min-width: 120px;">Cancel</button>
        <button type="button" class="btn btn-main" id="submitProgramChangeBtn" style="min-width: 120px;">Submit Request</button>
      </div>
    </div>
  </div>
</div>

<script>
// Show/hide "other reason" field
document.addEventListener('DOMContentLoaded', function() {
  const reasonSelect = document.getElementById('reasonForChange');
  const otherReasonField = document.getElementById('otherReasonField');

  if (reasonSelect) {
    reasonSelect.addEventListener('change', function() {
      if (this.value === 'other') {
        otherReasonField.style.display = 'block';
      } else {
        otherReasonField.style.display = 'none';
      }
    });
  }

  // Handle form submission
  const submitBtn = document.getElementById('submitProgramChangeBtn');
  if (submitBtn) {
    submitBtn.addEventListener('click', function() {
      const form = document.getElementById('changeProgramForm');
      if (form.checkValidity()) {
        // Form is valid, show success message
        alert('Your program change request has been submitted successfully! You will receive a confirmation email within 2-3 business days.');
        // Close modal
        const modal = bootstrap.Modal.getInstance(document.getElementById('changeProgramModal'));
        modal.hide();
        // Reset form
        form.reset();
      } else {
        // Form is invalid, show validation
        form.reportValidity();
      }
    });
  }
});
</script>

