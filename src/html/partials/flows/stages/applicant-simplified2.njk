			<!-- Enrollment Wizard - Document Submission Only -->
			{% include "partials/ui/enrollment-wizard-documents-only.njk" %}
		</div>

		<script>
		// Close alert functionality
		document.addEventListener('DOMContentLoaded', function() {
			// Transcript alert
			const closeBtn = document.getElementById('closeTranscriptAlert');
			const alert = document.getElementById('transcriptAlert');

			if (closeBtn && alert) {
				closeBtn.addEventListener('click', function() {
					alert.style.opacity = '0';
					alert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						alert.style.display = 'none';
					}, 300);
				});
			}

			// Outage alert
			const closeOutageBtn = document.getElementById('closeOutageAlert');
			const outageAlert = document.getElementById('outageAlert');

			if (closeOutageBtn && outageAlert) {
				closeOutageBtn.addEventListener('click', function() {
					outageAlert.style.opacity = '0';
					outageAlert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						outageAlert.style.display = 'none';
					}, 300);
				});
			}

			// Program alert
			const closeProgramBtn = document.getElementById('closeProgramAlert');
			const programAlert = document.getElementById('programAlert');

			if (closeProgramBtn && programAlert) {
				closeProgramBtn.addEventListener('click', function() {
					programAlert.style.opacity = '0';
					programAlert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						programAlert.style.display = 'none';
					}, 300);
				});
			}

			// Enrollment wizard alert
			const closeEnrollmentWizardBtn = document.getElementById('closeEnrollmentWizardAlert');
			const enrollmentWizardAlert = document.getElementById('enrollmentWizardAlert');

			if (closeEnrollmentWizardBtn && enrollmentWizardAlert) {
				closeEnrollmentWizardBtn.addEventListener('click', function() {
					enrollmentWizardAlert.style.opacity = '0';
					enrollmentWizardAlert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						enrollmentWizardAlert.style.display = 'none';
					}, 300);
				});
			}

			// Payment wizard alert
			const closePaymentWizardBtn = document.getElementById('closePaymentWizardAlert');
			const paymentWizardAlert = document.getElementById('paymentWizardAlert');

			if (closePaymentWizardBtn && paymentWizardAlert) {
				closePaymentWizardBtn.addEventListener('click', function() {
					paymentWizardAlert.style.opacity = '0';
					paymentWizardAlert.style.transform = 'translateY(-10px)';

					setTimeout(() => {
						paymentWizardAlert.style.display = 'none';
					}, 300);
				});
			}
		});
		</script>

		<script src="/js/payment-wizard.js"></script>

	</div>

