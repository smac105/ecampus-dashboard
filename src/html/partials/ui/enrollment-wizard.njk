          <div class="stage-main-content">
            <h2 class="enrollment-stage-title">Stage 3: Funding and Financial</h2>
            <p class="enrollment-stage-description">Complete the requirements below as prompted by the next stage.</p>

            <div class="enrollment-task-list">
              <!-- Funding -->
              <div class="task-group">
                <h3 class="task-group-title">Funding</h3>
