        Previous
      </button>

      <div class="footer-step-indicator">
        <span>Stage <span id="enrollmentCurrentStageNum">1</span> of 4</span>
      </div>

      <button type="button" class="btn-main" id="enrollmentNextBtn">
        Next
      </button>

      <button type="button" class="btn-main btn-one-icon" id="enrollmentCompleteBtn" style="display: none;">
        <i class="fas fa-check"></i> Complete Enrollment
      </button>
    </div>

    <!-- Close Button -->
    <button type="button" class="enrollment-wizard-close" id="enrollmentWizardCloseBtn" aria-label="Close wizard">
      <i class="fas fa-times"></i>
    </button>

