{# Enrollment Wizard - Screen Takeover #}
<!-- Enrollment Wizard Overlay -->
<div class="enrollment-wizard-overlay" id="enrollmentWizardOverlay">
  <div class="enrollment-wizard-container">

    <!-- Wizard Header -->
    <div class="enrollment-wizard-header">
      <h1 class="enrollment-wizard-title">Hello John!</h1>
      <p class="enrollment-wizard-subtitle">Welcome to Pre-Enrollment. Complete the steps below to get started on your journey.</p>
    </div>

    <!-- Tab-Style Progress Bar (4 Stages) -->
    <div class="enrollment-wizard-progress">
      <div class="enrollment-progress-tab active" data-stage="1">
        <div class="tab-content-wrapper">
          <span class="tab-number">1</span>
          <span class="tab-label">Profile Verification</span>
        </div>
      </div>
      <div class="enrollment-progress-tab" data-stage="2">
        <div class="tab-content-wrapper">
          <span class="tab-number">2</span>
          <span class="tab-label">Document Submission</span>
        </div>
      </div>
      <div class="enrollment-progress-tab" data-stage="3">
        <div class="tab-content-wrapper">
          <span class="tab-number">3</span>
          <span class="tab-label">Funding and Financial</span>
        </div>
      </div>
      <div class="enrollment-progress-tab" data-stage="4">
        <div class="tab-content-wrapper">
          <span class="tab-number">4</span>
          <span class="tab-label">Review and Confirm</span>
        </div>
      </div>
    </div>

    <!-- Wizard Content Area -->
    <div class="enrollment-wizard-content">

      <!-- Stage 1: Profile Verification -->
      <div class="enrollment-wizard-stage active" id="enrollmentStage1">
        <div class="stage-content-grid">

          <!-- Left Column: Stage Info & Task List -->
          <div class="stage-main-content">
            <h2 class="enrollment-stage-title">Stage 1: Profile Verification</h2>
            <p class="enrollment-stage-description">Complete the requirements below as prompted by the next stage.</p>

            <!-- Task List -->
            <div class="enrollment-task-list">
              <!-- Requirements & Reminders -->
              <div class="task-group">
                <h3 class="task-group-title">Requirements & Reminders</h3>
                <div class="task-item">
                  <div class="task-icon">
                    <i class="fa-solid fa-circle-check"></i>
                  </div>
                  <div class="task-details">
                    <p class="task-name">Verify Personal Information</p>
                    <p class="task-description">Ensure all contact details are accurate</p>
                  </div>
                  <div class="task-action">
                    <button class="task-btn task-btn-required" data-bs-toggle="modal" data-bs-target="#verifyInfoModal">
                      Required
                    </button>
                  </div>
                </div>

                <div class="task-item">
                  <div class="task-icon">
                    <i class="fa-solid fa-circle-check"></i>
                  </div>
                  <div class="task-details">
                    <p class="task-name">Confirm Program Selection</p>
                    <p class="task-description">Review your chosen degree program</p>
                  </div>
                  <div class="task-action">
                    <button class="task-btn task-btn-required">
                      Required
                    </button>
                  </div>
                </div>
              </div>

              <!-- Funding -->
              <div class="task-group">
                <h3 class="task-group-title">Additional Items</h3>
                <div class="task-item">
                  <div class="task-icon">
                    <i class="fa-solid fa-circle"></i>
                  </div>
                  <div class="task-details">
                    <p class="task-name">Update Emergency Contact</p>
                    <p class="task-description">Add or update emergency contact information</p>
                  </div>
                  <div class="task-action">
                    <button class="task-btn task-btn-optional">
                      Optional
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Right Column: Calendar/Action Items -->
          <div class="stage-sidebar">
            <div class="action-items-card">
              <h3>Action Items</h3>
              <p class="small-text mb-3">Items in this category:</p>
              <p class="count-number">3</p>
            </div>

            <!-- Mini Calendar -->
            <div class="mini-calendar-card">
              <div class="mini-calendar-header">
                <button class="month-nav">&lt;</button>
                <span class="month-year">April 2026</span>
                <button class="month-nav">&gt;</button>
              </div>
              <div class="mini-calendar-grid">
                <div class="calendar-day-name">S</div>
                <div class="calendar-day-name">M</div>
                <div class="calendar-day-name">T</div>
