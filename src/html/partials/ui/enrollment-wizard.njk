          <div class="stage-main-content">
            <h2 class="enrollment-stage-title">Stage 4: Review and Confirm</h2>
            <p class="enrollment-stage-description">Review all information and confirm to complete enrollment.</p>

            <!-- Summary Review -->
            <div class="enrollment-summary">
              <div class="summary-section">
                <h3>Profile Information</h3>
                <div class="summary-item">
                  <span class="summary-label">Name:</span>
                  <span class="summary-value">John Doe</span>
                </div>
                <div class="summary-item">
                  <span class="summary-label">Email:</span>
                  <span class="summary-value">john.doe@example.com</span>
                </div>
                <div class="summary-item">
                  <span class="summary-label">Program:</span>
                  <span class="summary-value">Master of Arts in History</span>
                </div>
              </div>

              <div class="summary-section">
                <h3>Documents</h3>
                <div class="summary-item">
                  <span class="summary-label">Photo ID:</span>
                  <span class="summary-value"><i class="fa-solid fa-check green"></i> Uploaded</span>
                </div>
                <div class="summary-item">
                  <span class="summary-label">Transcripts:</span>
                  <span class="summary-value"><i class="fa-solid fa-check green"></i> Requested</span>
                </div>
              </div>

              <div class="summary-section">
                <h3>Funding</h3>
                <div class="summary-item">
                  <span class="summary-label">Payment Method:</span>
                  <span class="summary-value">Financial Aid</span>
                </div>
                <div class="summary-item">
                  <span class="summary-label">FAFSA Status:</span>
                  <span class="summary-value">Completed</span>
                </div>
              </div>

              <div class="confirmation-checkbox">
                <input type="checkbox" id="enrollmentConfirmation" class="form-check-input">
                <label for="enrollmentConfirmation" class="form-check-label">
                  I confirm that all information provided is accurate and complete. I understand that submission of false information may result in denial of admission or dismissal from the university.
                </label>
              </div>
            </div>
          </div>

          <div class="stage-sidebar">
            <div class="action-items-card completion-card">
              <div class="completion-icon">
                <i class="fa-solid fa-check-circle"></i>
              </div>
              <h3>Almost Done!</h3>
              <p>Review your information and confirm to complete your enrollment.</p>
            </div>
          </div>

